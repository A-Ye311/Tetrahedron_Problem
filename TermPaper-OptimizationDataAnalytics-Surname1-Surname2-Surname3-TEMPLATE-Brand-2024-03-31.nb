   3.9904537527895145`*^9, 3.9904537585075016`*^9}, 
   3.990677803919407*^9},ExpressionUUID->"f3069855-fa7c-4747-946c-\
9d7721b4e4b4"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"x", "=", 
    RowBox[{"Sqrt", "[", "2", "]"}]}], ";", 
   RowBox[{"y", "=", 
    RowBox[{"2", "*", 
     RowBox[{"Sqrt", "[", "2", "]"}]}]}], ";", 
   RowBox[{"z", "=", 
    RowBox[{"3", "*", 
     RowBox[{"Sqrt", "[", "2", "]"}]}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{"Graphics3D", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Opacity", "[", "0.4", "]"}], ",", 
       RowBox[{"RGBColor", "[", 
        RowBox[{"0.2", ",", "0.5", ",", "0.8"}], "]"}], ",", 
       RowBox[{"Polygon", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", "0", ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"x", ",", "0", ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"0", ",", "y", ",", "0"}], "}"}]}], "}"}], "]"}]}], "}"}], 
     ",", 
     RowBox[{"(*", 
      RowBox[{"A1", "=", "2"}], "*)"}], 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Opacity", "[", "0.4", "]"}], ",", 
       RowBox[{"RGBColor", "[", 
        RowBox[{"0.8", ",", "0.2", ",", "0.2"}], "]"}], ",", 
       RowBox[{"Polygon", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", "0", ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"x", ",", "0", ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"0", ",", "0", ",", "z"}], "}"}]}], "}"}], "]"}]}], "}"}], 
     ",", 
     RowBox[{"(*", 
      RowBox[{"A2", "=", "3"}], "*)"}], 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Opacity", "[", "0.4", "]"}], ",", 
       RowBox[{"RGBColor", "[", 
        RowBox[{"0.2", ",", "0.8", ",", "0.2"}], "]"}], ",", 
       RowBox[{"Polygon", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", "0", ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"0", ",", "y", ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"0", ",", "0", ",", "z"}], "}"}]}], "}"}], "]"}]}], "}"}], 
     ",", 
     RowBox[{"(*", 
      RowBox[{"A3", "=", "6"}], "*)"}], 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Opacity", "[", "0.4", "]"}], ",", 
       RowBox[{"RGBColor", "[", 
        RowBox[{"1", ",", "0.6", ",", "0"}], "]"}], ",", 
       RowBox[{"Polygon", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"x", ",", "0", ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"0", ",", "y", ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"0", ",", "0", ",", "z"}], "}"}]}], "}"}], "]"}]}], 
      "}"}]}], "    ", 
    RowBox[{"(*", 
     RowBox[{"A4", "=", "7"}], "*)"}], "}"}], ",", 
   RowBox[{"Axes", "->", "True"}], ",", 
   RowBox[{"AxesLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<x=\[Sqrt]2\>\"", ",", "\"\<y=2\[Sqrt]2\>\"", 
      ",", "\"\<z=3\[Sqrt]2\>\""}], "}"}]}], ",", 
   RowBox[{
   "PlotLabel", 
    "->", "\"\<Right-angle Tetrahedron \[LongDash] Solution {2,3,6,7}\>\""}], 
   ",", 
   RowBox[{"Boxed", "->", "False"}], ",", 
   RowBox[{"ViewPoint", "->", 
