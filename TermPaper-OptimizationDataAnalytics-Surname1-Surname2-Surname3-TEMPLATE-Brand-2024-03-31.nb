 CellChangeTimes->{{3.990453761542551*^9, 3.990453761542551*^9}},
 CellLabel->"In[4]:=",ExpressionUUID->"82893124-a033-3b46-981f-d182e8c4ad83"],

Cell[BoxData[
 Graphics3DBox[{
   {RGBColor[0.2, 0.5, 0.8], Opacity[0.4], 
    Polygon3DBox[
     NCache[{{0, 0, 0}, {2^Rational[1, 2], 0, 0}, {
       0, 2 2^Rational[1, 2], 0}}, {{0, 0, 0}, {1.4142135623730951`, 0, 0}, {
       0, 2.8284271247461903`, 0}}]]}, 
   {RGBColor[0.8, 0.2, 0.2], Opacity[0.4], 
