     NCache[{{0, 0, 0}, {2^Rational[1, 2], 0, 0}, {
       0, 0, 3 2^Rational[1, 2]}}, {{0, 0, 0}, {1.4142135623730951`, 0, 0}, {
       0, 0, 4.242640687119286}}]]}, 
   {RGBColor[0.2, 0.8, 0.2], Opacity[0.4], 
    Polygon3DBox[
     NCache[{{0, 0, 0}, {0, 2 2^Rational[1, 2], 0}, {
       0, 0, 3 2^Rational[1, 2]}}, {{0, 0, 0}, {0, 2.8284271247461903`, 0}, {
       0, 0, 4.242640687119286}}]]}, 
   {RGBColor[1, 0.6, 0], Opacity[0.4], 
    Polygon3DBox[
