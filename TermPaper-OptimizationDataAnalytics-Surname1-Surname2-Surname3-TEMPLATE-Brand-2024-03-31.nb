Cell["\<\
Let a right-angle tetrahedron with edge lengths x, y, z > 0 be given. The \
three faces adjacent to the right-angle vertex have the following surface \
areas:\
\>", "Text",
 CellChangeTimes->{{3.6551323318137064`*^9, 3.655132346618133*^9}, {
   3.6558834788297663`*^9, 3.655883482105772*^9}, {3.655883581805547*^9, 
   3.655883589683561*^9}, {3.6558837346868153`*^9, 3.655883735919217*^9}, {
   3.694341574232729*^9, 3.694341596852769*^9}, {3.694342244717239*^9, 
   3.694342247462844*^9}, {3.694342333660995*^9, 3.694342343083412*^9}, {
   3.6943424202555304`*^9, 3.694342429299047*^9}, {3.6943424762647333`*^9, 
   3.694342484642213*^9}, {3.694342535512122*^9, 3.694342552269081*^9}, {
   3.6943425832578535`*^9, 3.694342597036641*^9}, {3.694342646046445*^9, 
   3.694342765915301*^9}, {3.694342880577859*^9, 3.694342892973568*^9}, {
   3.920005136849468*^9, 3.9200051373384686`*^9}, 
   3.990451959927845*^9},ExpressionUUID->"9fa5a7f9-5403-1c4d-b45f-\
fc3fdf894aee"],

Cell[BoxData[
 RowBox[{" ", 
  RowBox[{
   RowBox[{
    SubscriptBox["A", "1"], "=", 
    FractionBox["xy", "2"]}], ",", " ", 
   RowBox[{
    SubscriptBox["A", "2"], "=", 
    FractionBox["xz", "2"]}], ",", " ", 
   RowBox[{
    SubscriptBox["A", "3"], "=", 
    FractionBox["yz", "2"]}]}]}]], "Input",
 CellChangeTimes->{
  3.694345762940171*^9, {3.9904519657512856`*^9, 
   3.9904520380841675`*^9}},ExpressionUUID->"25190add-2924-467f-8bf7-\
975d689e5f07"],

Cell["\<\
The area of the fourth face \[LongDash] the hypotenuse face \[LongDash] \
follows directly from the edge lengths:\
\>", "Text",
 CellChangeTimes->{{3.990452049130247*^9, 3.9904520520463448`*^9}, 
   3.990461602439844*^9},ExpressionUUID->"d0827fd6-3b96-4547-9abf-\
3467114ac4c1"],

Cell[BoxData[
 RowBox[{
  SubscriptBox["A", "4"], "=", 
  FractionBox[
   SqrtBox[
    RowBox[{
     RowBox[{
      SuperscriptBox["x", "2"], 
      SuperscriptBox["y", "2"]}], "+", 
     RowBox[{
      SuperscriptBox["x", "2"], 
      SuperscriptBox["z", "2"]}], "+", 
     RowBox[{
      SuperscriptBox["y", "2"], 
      SuperscriptBox["z", "2"]}]}]], "2"]}]], "Input",
 CellChangeTimes->{{3.990452062820402*^9, 3.9904521204431076`*^9}, {
  3.990452322124008*^9, 
  3.9904523493708725`*^9}},ExpressionUUID->"8b54b6e7-5cdd-e042-a3af-\
99f4d5babebf"],

Cell["\<\
It can be shown that these four areas satisfy the following relationship:\
\>", "Text",
 CellChangeTimes->{{3.990452360340946*^9, 3.9904523648229504`*^9}, 
   3.99046159953784*^9},ExpressionUUID->"1f11e8a4-1f6a-eb4a-b68e-\
d0d88be7c629"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubsuperscriptBox["A", "1", "2"], "+", 
   SubsuperscriptBox["A", "2", "2"], "+", 
   SubsuperscriptBox["A", "3", "2"]}], "=", 
  SubsuperscriptBox["A", "4", "2"]}]], "Input",
 CellChangeTimes->{{3.9904523726403866`*^9, 3.990452383166353*^9}, {
  3.9904524299174633`*^9, 
  3.9904524798602295`*^9}},ExpressionUUID->"3a67858a-a745-cd4e-bf07-\
1051fb315b2c"],

Cell["\<\
This is known as De Gua' s Theorem\[LongDash]the three - dimensional analogue \
of the Pythagorean Theorem\[LongDash]and was derived as part of the solution \
process . It establishes that A4 is fully determined once A1, A2, and A3 are \
known . The objective of this problem is to find all configurations \
satisfying the following two conditions simultaneously:\
\>", "Text",
 CellChangeTimes->{{3.990452487888756*^9, 3.9904524971572075`*^9}, 
   3.990461595403324*^9},ExpressionUUID->"35b45854-3018-9941-af73-\
259516ab44b7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   SubscriptBox["A", "1"], "+", 
   SubscriptBox["A", "2"], "+", 
   SubscriptBox["A", "3"], "+", 
   SubscriptBox["A", "4"]}], " ", "=", " ", "18"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    SubscriptBox["A", "1"], "\[Epsilon]", " ", "\:2115", " ", "for", " ", 
    "i"}], "=", "1"}], ",", "2", ",", "3", ",", "4"}]}], "Input",
 CellChangeTimes->{{3.9904525072496223`*^9, 3.990452546243204*^9}, {
  3.990452929776308*^9, 
  3.990452962812275*^9}},ExpressionUUID->"b98937ea-69d2-fa45-b660-\
7534763fece7"],

Cell["\<\
The problem therefore reduces to finding all integer triplets (A1, A2, A3) \
such that the resulting A4 is also a natural number and the total sum equals \
18.\
\>", "Text",
 CellChangeTimes->{{3.990452977564764*^9, 
  3.990452983694853*^9}},ExpressionUUID->"729ceee0-54fc-f647-b396-\
eb7ac3166527"]
}, Open  ]],

Cell[CellGroupData[{

Cell["4 Solution", "Section",
 PageBreakAbove->True,
 CellChangeTimes->{{3.694341537930465*^9, 3.694341550254487*^9}, {
   3.694342355079833*^9, 3.694342363410248*^9}, 3.6943428651189747`*^9, {
   3.6943430193857985`*^9, 3.694343019923829*^9}, {3.6943431695433865`*^9, 
   3.694343174763685*^9}, 3.694345457572358*^9, 
   3.9200052107218494`*^9},ExpressionUUID->"e0ce679d-baae-4e3f-955a-\
2426a5ad958a"],

Cell[CellGroupData[{

Cell["4.1 Mathematical Model", "Subsection",
 CellChangeTimes->{{3.6943454921732183`*^9, 3.694345497976429*^9}, 
   3.990453044362276*^9},ExpressionUUID->"3847f262-4c0c-46d6-85cc-\
4ef49cf728fc"],

Cell["\<\
The solution approach exploits a key algebraic property of the three face \
areas A1, A2, and A3. Multiplying them together yields:\
\>", "Text",
 CellChangeTimes->{{3.6551323318137064`*^9, 3.655132346618133*^9}, {
   3.6558834788297663`*^9, 3.655883482105772*^9}, {3.655883581805547*^9, 
   3.655883589683561*^9}, {3.6558837346868153`*^9, 3.655883735919217*^9}, {
   3.694341574232729*^9, 3.694341596852769*^9}, {3.694342244717239*^9, 
   3.694342247462844*^9}, {3.694342333660995*^9, 3.694342343083412*^9}, {
   3.6943424202555304`*^9, 3.694342429299047*^9}, {3.6943424762647333`*^9, 
   3.694342484642213*^9}, {3.694342535512122*^9, 3.694342552269081*^9}, {
   3.6943425832578535`*^9, 3.694342597036641*^9}, {3.694342646046445*^9, 
   3.694342765915301*^9}, {3.694342880577859*^9, 3.694342892973568*^9}, {
   3.920005136849468*^9, 3.9200051373384686`*^9}, 
   3.9904530490801907`*^9},ExpressionUUID->"dd5889fc-b7b8-1e4d-ac00-\
ef278f9515c5"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    SubscriptBox["A", "1"], "\[Cross]", 
    SubscriptBox["A", "2"], "\[Cross]", 
    SubscriptBox["A", "3"]}], "=", 
   RowBox[{
    RowBox[{
     FractionBox["xy", "2"], "\[Cross]", 
     FractionBox["xz", "2"], "\[Cross]", 
     FractionBox["yz", "2"]}], "=", 
    FractionBox[
     RowBox[{
      SuperscriptBox["x", "2"], 
      SuperscriptBox["y", "2"], 
      SuperscriptBox["z", "2"]}], "8"]}]}], "\n"}]], "Input",
 CellChangeTimes->{{3.9904530546342144`*^9, 3.990453181515135*^9}, {
  3.9904532473825703`*^9, 
  3.990453359713236*^9}},ExpressionUUID->"2b8d5ec3-6ba4-7e4f-b0a0-\
ff47ba29ee41"],

Cell["This directly implies :", "Text",
 CellChangeTimes->{{3.9904533680979443`*^9, 
  3.990453374316719*^9}},ExpressionUUID->"331375c1-06b3-d64d-9699-\
03811dec39d2"],

Cell[BoxData[
 RowBox[{"xyz", "=", 
  SqrtBox[
   RowBox[{"8", "\[Cross]", 
    SubscriptBox["A", "1"], "\[Cross]", 
    SubscriptBox["A", "2"], "\[Cross]", 
    SubscriptBox["A", "3"]}]]}]], "Input",
 CellChangeTimes->{{3.9904533788595943`*^9, 
  3.990453433315296*^9}},ExpressionUUID->"70f4aa1f-3c70-9f4b-bd8c-\
b78306e40325"],

Cell["\<\
Once xyz is known, the individual edge lengths can be recovered by dividing \
through the respective face products :\
\>", "Text",
 CellChangeTimes->{{3.990453439516323*^9, 
  3.9904534473939667`*^9}},ExpressionUUID->"71c8bcc5-a571-de40-9358-\
643afde52c40"],

Cell[BoxData[
 RowBox[{
  RowBox[{"x", "=", 
   FractionBox["xyz", "yz"]}], ",", " ", 
  RowBox[{"y", "=", 
   FractionBox["xyz", "xz"]}], ",", " ", 
  RowBox[{"z", "=", 
   FractionBox["xyz", "xy"]}]}]], "Input",
 CellChangeTimes->{{3.9904534630067196`*^9, 3.9904534913117657`*^9}, {
  3.9904535552867146`*^9, 
  3.990453572960682*^9}},ExpressionUUID->"b58ada4c-d645-3043-8399-\
bcc407bd4f64"],

Cell["\<\
This approach avoids solving a full system of equations and reduces the \
problem to a simple division once the areas are known.\
\>", "Text",
 CellChangeTimes->{{3.99045358157992*^9, 3.9904535865098457`*^9}, 
   3.990461608024132*^9},ExpressionUUID->"398fab66-02fc-f545-987f-\
35b93ce3b113"]
}, Open  ]],

Cell[CellGroupData[{

Cell["4.2 Systematic Search", "Subsection",
 CellChangeTimes->{{3.6943454921732183`*^9, 3.6943455089276485`*^9}, 
   3.9904535966306705`*^9},ExpressionUUID->"64d905b6-1c05-4671-a397-\
d9051e682947"],

Cell["\<\
Since A4 is fully determined by A1, A2, and A3 via De Gua\[CloseCurlyQuote]s \
Theorem, the problem reduces to searching all integer triplets (A1, A2, A3) \
and checking whether the resulting A4 is also a natural number and the total \
sum equals 18. To account for all valid arrangements, permutations of the leg \
areas are considered as distinct solutions. This search is implemented in \
Mathematica as follows:\
\>", "Text",
 CellChangeTimes->{{3.6551323318137064`*^9, 3.655132346618133*^9}, {
  3.6558834788297663`*^9, 3.655883482105772*^9}, {3.655883581805547*^9, 
  3.655883589683561*^9}, {3.6558837346868153`*^9, 3.655883735919217*^9}, {
  3.694341574232729*^9, 3.694341596852769*^9}, {3.694342244717239*^9, 
  3.694342247462844*^9}, {3.694342333660995*^9, 3.694342343083412*^9}, {
  3.6943424202555304`*^9, 3.694342429299047*^9}, {3.6943424762647333`*^9, 
  3.694342484642213*^9}, {3.694342535512122*^9, 3.694342552269081*^9}, {
  3.6943425832578535`*^9, 3.694342597036641*^9}, {3.694342646046445*^9, 
  3.694342765915301*^9}, {3.694342880577859*^9, 3.694342892973568*^9}, {
  3.920005136849468*^9, 3.9200051373384686`*^9}, {3.9904536031079235`*^9, 
  3.9904536133700294`*^9}},ExpressionUUID->"720fd0cf-3b1a-5641-91db-\
187a96969d99"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{" ", 
  RowBox[{
   RowBox[{
    RowBox[{"solutions", "=", 
     RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"A4", "=", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{"A1", "^", "2"}], "+", 
          RowBox[{"A2", "^", "2"}], "+", 
          RowBox[{"A3", "^", "2"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"IntegerQ", "[", "A4", "]"}], "&&", 
          RowBox[{
           RowBox[{"A1", "+", "A2", "+", "A3", "+", "A4"}], "==", "18"}]}], ",", 
         RowBox[{"AppendTo", "[", 
          RowBox[{"solutions", ",", 
           RowBox[{"{", 
            RowBox[{"A1", ",", "A2", ",", "A3", ",", "A4"}], "}"}]}], "]"}]}],
         "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"A1", ",", "1", ",", "15"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"A2", ",", "1", ",", "15"}], "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"keine", " ", "Einschr\[ADoubleDot]nkung"}], "\[RightArrow]", 
        RowBox[{"alle", " ", "Permutationen"}]}], "*)"}], 
      RowBox[{"{", 
       RowBox[{"A3", ",", "1", ",", "15"}], "}"}]}], "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Ergebnisse", " ", "ausgeben"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Grid", "[", 
    RowBox[{
     RowBox[{"Prepend", "[", 
      RowBox[{"solutions", ",", 
       RowBox[{"{", 
        RowBox[{"\"\<A1\>\"", ",", "\"\<A2\>\"", ",", "\"\<A3\>\"", 
         ",", "\"\<A4\>\""}], "}"}]}], "]"}], ",", 
     RowBox[{"Frame", "->", "All"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{3.6943456316374636`*^9, 3.990453619827881*^9},
 CellLabel->"In[1]:=",ExpressionUUID->"63973c09-62b7-45ce-8eee-a870279ee06a"],

Cell[BoxData[
 TagBox[GridBox[{
    {"\<\"A1\"\>", "\<\"A2\"\>", "\<\"A3\"\>", "\<\"A4\"\>"},
    {"2", "3", "6", "7"},
    {"2", "6", "3", "7"},
    {"3", "2", "6", "7"},
    {"3", "6", "2", "7"},
    {"6", "2", "3", "7"},
    {"6", "3", "2", "7"}
   },
   AutoDelete->False,
   GridBoxFrame->{"Columns" -> {{True}}, "Rows" -> {{True}}},
   GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
  "Grid"]], "Output",
 CellChangeTimes->{3.990453628937849*^9},
 CellLabel->"Out[3]=",ExpressionUUID->"c4d54ae6-24d7-5248-a6b1-7783ab899168"]
}, Open  ]],

Cell["\<\
Each permutation corresponds to a different assignment of the edge lengths x, \
y, z\[LongDash]and therefore a geometrically distinct tetrahedron, even \
though the set of surface areas remains identical . A4 remains 7 in all cases \
since De Gua' s Theorem is symmetric in A1, A2, A3 .\
\>", "Text",
 CellChangeTimes->{{3.9904536391327705`*^9, 
  3.9904536452437515`*^9}},ExpressionUUID->"e5c14535-7fa6-b243-a682-\
e2864d6e6ac2"]
}, Open  ]],

Cell[CellGroupData[{

Cell["4.3 Visualization", "Subsection",
