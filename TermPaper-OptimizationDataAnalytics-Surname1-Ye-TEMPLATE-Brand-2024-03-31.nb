Cell["2 Introduction", "Section",
 PageBreakAbove->True,
 CellChangeTimes->{{3.694341537930465*^9, 3.694341550254487*^9}, {
   3.694342355079833*^9, 3.694342363410248*^9}, 3.6943428651189747`*^9, {
   3.6943430193857985`*^9, 3.694343019923829*^9}, {3.6943431695433865`*^9, 
   3.694343174763685*^9}, 3.694345439835127*^9, 3.920005199087162*^9, 
   3.99045269259453*^9},ExpressionUUID->"cdc5618b-ff33-4f5c-8ceb-\
21a3425e82dc"],

Cell["\<\
This report was prepared as part of the course Optimisation and Simulation. \
The problem at hand serves as a practical example of how mathematical \
optimisation techniques and computational tools can be combined to solve \
geometric problems systematically.
A right-angle tetrahedron is a three-dimensional geometric object consisting \
of four triangular faces, where three of the four faces meet at a common \
vertex at right angles to one another. This structure is the natural \
three-dimensional extension of a right-angle triangle. \
\>", "Text",
 CellChangeTimes->{{3.6551323318137064`*^9, 3.655132346618133*^9}, {
  3.6558834788297663`*^9, 3.655883482105772*^9}, {3.655883581805547*^9, 
  3.655883589683561*^9}, {3.6558837346868153`*^9, 3.655883735919217*^9}, {
  3.694341574232729*^9, 3.694341596852769*^9}, {3.694342244717239*^9, 
  3.694342247462844*^9}, {3.694342333660995*^9, 3.694342343083412*^9}, {
  3.6943424202555304`*^9, 3.694342429299047*^9}, {3.6943424762647333`*^9, 
  3.694342484642213*^9}, {3.694342535512122*^9, 3.694342552269081*^9}, {
  3.6943425832578535`*^9, 3.694342597036641*^9}, {3.694342646046445*^9, 
  3.694342765915301*^9}, {3.694342880577859*^9, 3.694342892973568*^9}, {
  3.920005136849468*^9, 3.9200051373384686`*^9}, {3.990451867152336*^9, 
  3.990451869706068*^9}, {3.990452411325676*^9, 3.990452415695072*^9}, {
  3.990684625898201*^9, 
  3.9906846513652973`*^9}},ExpressionUUID->"5c85260f-b5be-694f-b4cd-\
b8ee9ff9cd14"]
}, Open  ]],

Cell[CellGroupData[{

Cell["3 Problem Statement", "Section",
 PageBreakAbove->True,
 CellChangeTimes->{{3.694341537930465*^9, 3.694341550254487*^9}, {
   3.694342355079833*^9, 3.694342363410248*^9}, 3.6943428651189747`*^9, {
   3.6943430193857985`*^9, 3.694343019923829*^9}, {3.6943431695433865`*^9, 
   3.694343174763685*^9}, 3.694345448914343*^9, 
   3.920005205066906*^9},ExpressionUUID->"82473837-570c-4bf9-b27a-\
b88eb03e0623"],

Cell["\<\
Let a right-angle tetrahedron with edge lengths x, y, z > 0 be given. The \
three faces adjacent to the right-angle vertex have the following surface \
areas:\
\>", "Text",
 CellChangeTimes->{{3.6551323318137064`*^9, 3.655132346618133*^9}, {
   3.6558834788297663`*^9, 3.655883482105772*^9}, {3.655883581805547*^9, 
   3.655883589683561*^9}, {3.6558837346868153`*^9, 3.655883735919217*^9}, {
   3.694341574232729*^9, 3.694341596852769*^9}, {3.694342244717239*^9, 
   3.694342247462844*^9}, {3.694342333660995*^9, 3.694342343083412*^9}, {
   3.6943424202555304`*^9, 3.694342429299047*^9}, {3.6943424762647333`*^9, 
   3.694342484642213*^9}, {3.694342535512122*^9, 3.694342552269081*^9}, {
   3.6943425832578535`*^9, 3.694342597036641*^9}, {3.694342646046445*^9, 
   3.694342765915301*^9}, {3.694342880577859*^9, 3.694342892973568*^9}, {
   3.920005136849468*^9, 3.9200051373384686`*^9}, 
   3.990451959927845*^9},ExpressionUUID->"9fa5a7f9-5403-1c4d-b45f-\
fc3fdf894aee"],

Cell[BoxData[
 RowBox[{" ", 
  RowBox[{
   RowBox[{
    SubscriptBox["A", "1"], "=", 
    FractionBox["xy", "2"]}], ",", " ", 
   RowBox[{
    SubscriptBox["A", "2"], "=", 
    FractionBox["xz", "2"]}], ",", " ", 
   RowBox[{
    SubscriptBox["A", "3"], "=", 
    FractionBox["yz", "2"]}]}]}]], "Input",
 CellChangeTimes->{
  3.694345762940171*^9, {3.9904519657512856`*^9, 
   3.9904520380841675`*^9}},ExpressionUUID->"25190add-2924-467f-8bf7-\
975d689e5f07"],

Cell[BoxData[
 RowBox[{
  SubscriptBox["A", "4"], "=", 
  FractionBox[
   SqrtBox[
    RowBox[{
     RowBox[{
      SuperscriptBox["x", "2"], 
      SuperscriptBox["y", "2"]}], "+", 
     RowBox[{
      SuperscriptBox["x", "2"], 
      SuperscriptBox["z", "2"]}], "+", 
     RowBox[{
      SuperscriptBox["y", "2"], 
      SuperscriptBox["z", "2"]}]}]], "2"]}]], "Input",
 CellChangeTimes->{{3.990452049130247*^9, 3.9904520520463448`*^9}, 
   3.990461602439844*^9, {3.9906832812104435`*^9, 3.9906833016273193`*^9}, 
   3.990684154159897*^9},ExpressionUUID->"d0827fd6-3b96-4547-9abf-\
3467114ac4c1"],

Cell["\<\
It can be shown that these four areas satisfy the following relationship:\
\>", "Text",
 CellChangeTimes->{{3.990452360340946*^9, 3.9904523648229504`*^9}, 
   3.99046159953784*^9},ExpressionUUID->"1f11e8a4-1f6a-eb4a-b68e-\
d0d88be7c629"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubsuperscriptBox["A", "1", "2"], "+", 
   SubsuperscriptBox["A", "2", "2"], "+", 
   SubsuperscriptBox["A", "3", "2"]}], "=", 
  SubsuperscriptBox["A", "4", "2"]}]], "Input",
 CellChangeTimes->{{3.9904523726403866`*^9, 3.990452383166353*^9}, {
  3.9904524299174633`*^9, 
  3.9904524798602295`*^9}},ExpressionUUID->"3a67858a-a745-cd4e-bf07-\
1051fb315b2c"],

Cell["\<\
This is known as De Gua' s Theorem and was derived as part of the solution \
process . It establishes that A4 is fully determined once A1, A2, and A3 are \
known . 

Our constraints: \
\>", "Text",
 CellChangeTimes->{{3.990452487888756*^9, 3.9904524971572075`*^9}, 
   3.990461595403324*^9, {3.9906830173495274`*^9, 3.9906830298910847`*^9}, {
   3.9906832285108643`*^9, 3.99068322894475*^9}, {3.990683265632801*^9, 
   3.9906832719112263`*^9}, {3.9906839107205906`*^9, 
   3.990683917779646*^9}},ExpressionUUID->"35b45854-3018-9941-af73-\
259516ab44b7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   SubscriptBox["A", "1"], "+", 
   SubscriptBox["A", "2"], "+", 
   SubscriptBox["A", "3"], "+", 
   SubscriptBox["A", "4"]}], " ", "=", " ", "18"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    SubscriptBox["A", "1"], "\[Epsilon]", " ", "\:2115", " ", "for", " ", 
    "i"}], "=", "1"}], ",", "2", ",", "3", ",", "4"}]}], "Input",
 CellChangeTimes->{{3.9904525072496223`*^9, 3.990452546243204*^9}, {
  3.990452929776308*^9, 
  3.990452962812275*^9}},ExpressionUUID->"b98937ea-69d2-fa45-b660-\
7534763fece7"],

Cell["\<\
The problem therefore reduces to finding all integer triplets (A1, A2, A3) \
such that the resulting A4 is also a natural number and the total sum equals \
18.\
\>", "Text",
 CellChangeTimes->{{3.990452977564764*^9, 
  3.990452983694853*^9}},ExpressionUUID->"729ceee0-54fc-f647-b396-\
eb7ac3166527"],

Cell["Based on our informations is this our Quality Function:", "Text",
 CellChangeTimes->{{3.9906843591271286`*^9, 3.990684378423479*^9}, {
  3.990684737170374*^9, 
  3.9906847544678955`*^9}},ExpressionUUID->"881540b2-1e3a-da4c-b759-\
56a8c37e667b"],

Cell[BoxData[{
 RowBox[{"QF", "=", 
  RowBox[{
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["A", "1"], "+", 
      SubscriptBox["A", "2"], "+", 
      SubscriptBox["A", "3"], "+", 
      SubscriptBox["A", "4"], " ", "-", "18"}], ")"}], "2"], " ", "=", " ", 
   "0"}]}], "\[IndentingNewLine]", 
 RowBox[{"QF", " ", "=", " ", 
  RowBox[{
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["A", "1"], "+", 
      SubscriptBox["A", "2"], "+", 
      SubscriptBox["A", "3"], " ", "+", 
      SqrtBox[
       RowBox[{
        SubsuperscriptBox["A", "1", "2"], "+", 
        SubsuperscriptBox["A", "2", "2"], "+", 
        SubsuperscriptBox["A", "3", "2"]}]], "-", "18"}], ")"}], "2"], "=", 
   " ", "0"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"QF", 
   RowBox[{"(", 
    RowBox[{"x", ",", "y", ",", "z"}], ")"}]}], "=", " ", 
  RowBox[{
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      FractionBox["xy", "2"], "+", 
      FractionBox["xz", "2"], "+", 
      FractionBox["yz", "2"], " ", "+", " ", 
      FractionBox[
       SqrtBox[
        RowBox[{
         RowBox[{
          SuperscriptBox["x", "2"], 
          SuperscriptBox["y", "2"]}], "+", 
         RowBox[{
          SuperscriptBox["x", "2"], 
          SuperscriptBox["z", "2"]}], "+", 
         RowBox[{
          SuperscriptBox["y", "2"], 
          SuperscriptBox["z", "2"]}]}]], "2"], " ", "-", "18"}], ")"}], "2"], 
   " ", "=", " ", "0"}]}]}], "Input",
 CellChangeTimes->{{3.9912217155701447`*^9, 3.991221802499235*^9}, {
  3.99122191997538*^9, 
  3.99122192185968*^9}},ExpressionUUID->"1a05b1af-407d-304c-81a2-\
b82788b74035"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "4 Solution",
 Cell[BoxData[""], "Input",
  CellChangeTimes->{{3.9906839291701984`*^9, 3.9906839335792427`*^9}, {
   3.9906840387992573`*^9, 3.990684115246788*^9}, {3.990684223587511*^9, 
   3.9906843393951073`*^9}},ExpressionUUID->
  "f47640dd-ba74-8849-8e2f-fb4b9945262a"]
}], "Section",
 PageBreakAbove->True,
 CellChangeTimes->{{3.694341537930465*^9, 3.694341550254487*^9}, {
   3.694342355079833*^9, 3.694342363410248*^9}, 3.6943428651189747`*^9, {
   3.6943430193857985`*^9, 3.694343019923829*^9}, {3.6943431695433865`*^9, 
   3.694343174763685*^9}, 3.694345457572358*^9, 3.9200052107218494`*^9, 
   3.9906839211539326`*^9, 3.9906840327960777`*^9, {3.990684425691986*^9, 
   3.9906844292832603`*^9}, {3.9912218087302246`*^9, 
   3.9912218097970066`*^9}},ExpressionUUID->"e0ce679d-baae-4e3f-955a-\
2426a5ad958a"],

Cell[CellGroupData[{

Cell["4.1 Rearrange mathematical formula", "Subsection",
 CellChangeTimes->{{3.9906829694227276`*^9, 3.9906829885139256`*^9}, {
   3.990683240045719*^9, 3.990683253407587*^9}, 
   3.9906844331032734`*^9},ExpressionUUID->"fab2e7da-43b9-4640-a576-\
3039675e656a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    SubscriptBox["A", "1"], "\[Cross]", 
    SubscriptBox["A", "2"], "\[Cross]", 
    SubscriptBox["A", "3"]}], "=", 
   RowBox[{
    RowBox[{
     FractionBox["xy", "2"], "\[Cross]", 
     FractionBox["xz", "2"], "\[Cross]", 
     FractionBox["yz", "2"]}], "=", 
    FractionBox[
     RowBox[{
      SuperscriptBox["x", "2"], 
      SuperscriptBox["y", "2"], 
      SuperscriptBox["z", "2"]}], "8"]}]}], "\n"}]], "Input",
 CellChangeTimes->{{3.6551323318137064`*^9, 3.655132346618133*^9}, {
   3.6558834788297663`*^9, 3.655883482105772*^9}, {3.655883581805547*^9, 
   3.655883589683561*^9}, {3.6558837346868153`*^9, 3.655883735919217*^9}, {
   3.694341574232729*^9, 3.694341596852769*^9}, {3.694342244717239*^9, 
   3.694342247462844*^9}, {3.694342333660995*^9, 3.694342343083412*^9}, {
   3.6943424202555304`*^9, 3.694342429299047*^9}, {3.6943424762647333`*^9, 
   3.694342484642213*^9}, {3.694342535512122*^9, 3.694342552269081*^9}, {
   3.6943425832578535`*^9, 3.694342597036641*^9}, {3.694342646046445*^9, 
   3.694342765915301*^9}, {3.694342880577859*^9, 3.694342892973568*^9}, {
   3.920005136849468*^9, 3.9200051373384686`*^9}, 3.9904530490801907`*^9, {
   3.9906827032540646`*^9, 3.990682704525078*^9}, {3.9906827765189037`*^9, 
   3.9906827886063175`*^9}, 3.9906833458303394`*^9, 3.990683961678097*^9, 
   3.990684125702921*^9},ExpressionUUID->"dd5889fc-b7b8-1e4d-ac00-\
ef278f9515c5"],

Cell["This directly implies :", "Text",
 CellChangeTimes->{{3.9904533680979443`*^9, 
  3.990453374316719*^9}},ExpressionUUID->"331375c1-06b3-d64d-9699-\
03811dec39d2"],

Cell[BoxData[
 RowBox[{"xyz", "=", 
  SqrtBox[
   RowBox[{"8", "\[Cross]", 
    SubscriptBox["A", "1"], "\[Cross]", 
    SubscriptBox["A", "2"], "\[Cross]", 
    SubscriptBox["A", "3"]}]]}]], "Input",
 CellChangeTimes->{{3.9904533788595943`*^9, 
  3.990453433315296*^9}},ExpressionUUID->"70f4aa1f-3c70-9f4b-bd8c-\
b78306e40325"],

Cell["\<\
Once xyz is known, the individual edge lengths can be recovered by dividing \
through the respective face products :\
\>", "Text",
 CellChangeTimes->{{3.990453439516323*^9, 
  3.9904534473939667`*^9}},ExpressionUUID->"71c8bcc5-a571-de40-9358-\
643afde52c40"],

Cell[BoxData[
 RowBox[{
  RowBox[{"x", "=", 
   FractionBox["xyz", "yz"]}], ",", " ", 
  RowBox[{"y", "=", 
   FractionBox["xyz", "xz"]}], ",", " ", 
  RowBox[{"z", "=", 
   FractionBox["xyz", "xy"]}]}]], "Input",
 CellChangeTimes->{{3.9904534630067196`*^9, 3.9904534913117657`*^9}, {
  3.9904535552867146`*^9, 
  3.990453572960682*^9}},ExpressionUUID->"b58ada4c-d645-3043-8399-\
bcc407bd4f64"],

Cell["\<\
This approach avoids solving a full system of equations and reduces the \
problem to a simple division once the areas are known.\
\>", "Text",
 CellChangeTimes->{{3.99045358157992*^9, 3.9904535865098457`*^9}, 
   3.990461608024132*^9},ExpressionUUID->"398fab66-02fc-f545-987f-\
35b93ce3b113"]
}, Open  ]],

Cell[CellGroupData[{

Cell["4.2 Systematic Search", "Subsection",
 CellChangeTimes->{{3.6943454921732183`*^9, 3.6943455089276485`*^9}, 
   3.9904535966306705`*^9},ExpressionUUID->"64d905b6-1c05-4671-a397-\
d9051e682947"],

Cell["\<\
Since A4 is fully determined by A1, A2, and A3 via De Gua\[CloseCurlyQuote]s \
Theorem, the problem reduces to searching all integer triplets (A1, A2, A3) \
and checking whether the resulting A4 is also a natural number and the total \
sum equals 18. To account for all valid arrangements, permutations of the leg \
areas are considered as distinct solutions. This search is implemented in \
Mathematica as follows:\
\>", "Text",
 CellChangeTimes->{{3.6551323318137064`*^9, 3.655132346618133*^9}, {
  3.6558834788297663`*^9, 3.655883482105772*^9}, {3.655883581805547*^9, 
  3.655883589683561*^9}, {3.6558837346868153`*^9, 3.655883735919217*^9}, {
  3.694341574232729*^9, 3.694341596852769*^9}, {3.694342244717239*^9, 
  3.694342247462844*^9}, {3.694342333660995*^9, 3.694342343083412*^9}, {
  3.6943424202555304`*^9, 3.694342429299047*^9}, {3.6943424762647333`*^9, 
  3.694342484642213*^9}, {3.694342535512122*^9, 3.694342552269081*^9}, {
  3.6943425832578535`*^9, 3.694342597036641*^9}, {3.694342646046445*^9, 
  3.694342765915301*^9}, {3.694342880577859*^9, 3.694342892973568*^9}, {
  3.920005136849468*^9, 3.9200051373384686`*^9}, {3.9904536031079235`*^9, 
  3.9904536133700294`*^9}},ExpressionUUID->"720fd0cf-3b1a-5641-91db-\
187a96969d99"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{" ", 
  RowBox[{
   RowBox[{
    RowBox[{"solutions", "=", 
     RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"A4", "=", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{"A1", "^", "2"}], "+", 
          RowBox[{"A2", "^", "2"}], "+", 
          RowBox[{"A3", "^", "2"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"IntegerQ", "[", "A4", "]"}], "&&", 
          RowBox[{
           RowBox[{"A1", "+", "A2", "+", "A3", "+", "A4"}], "==", "18"}]}], ",", 
         RowBox[{"AppendTo", "[", 
          RowBox[{"solutions", ",", 
           RowBox[{"{", 
            RowBox[{"A1", ",", "A2", ",", "A3", ",", "A4"}], "}"}]}], "]"}]}],
         "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"A1", ",", "1", ",", "15"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"A2", ",", "1", ",", "15"}], "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{"keine", " ", "Einschr\[ADoubleDot]nkung"}], "*)"}], 
      RowBox[{"{", 
       RowBox[{"A3", ",", "1", ",", "15"}], "}"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"Grid", "[", 
    RowBox[{
     RowBox[{"Prepend", "[", 
      RowBox[{"solutions", ",", 
       RowBox[{"{", 
        RowBox[{"\"\<A1\>\"", ",", "\"\<A2\>\"", ",", "\"\<A3\>\"", 
         ",", "\"\<A4\>\""}], "}"}]}], "]"}], ",", 
     RowBox[{"Frame", "->", "All"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{
  3.6943456316374636`*^9, 3.990453619827881*^9, {3.9906829215736275`*^9, 
   3.9906829351026287`*^9}},ExpressionUUID->"63973c09-62b7-45ce-8eee-\
a870279ee06a"],

Cell[BoxData[
 TagBox[GridBox[{
    {"\<\"A1\"\>", "\<\"A2\"\>", "\<\"A3\"\>", "\<\"A4\"\>"},
    {"2", "3", "6", "7"},
    {"2", "6", "3", "7"},
    {"3", "2", "6", "7"},
    {"3", "6", "2", "7"},
    {"6", "2", "3", "7"},
    {"6", "3", "2", "7"}
   },
   AutoDelete->False,
   GridBoxFrame->{"Columns" -> {{True}}, "Rows" -> {{True}}},
   GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
  "Grid"]], "Output",
 CellChangeTimes->{3.990453628937849*^9},
 CellLabel->"Out[3]=",ExpressionUUID->"c4d54ae6-24d7-5248-a6b1-7783ab899168"]
}, Open  ]],

Cell["\<\
Each permutation corresponds to a different assignment of the edge lengths x, \
y, z and therefore a geometrically distinct tetrahedron, even though the set \
of surface areas remains identical . A4 remains 7 in all cases since De Gua' \
s Theorem is symmetric in A1, A2, A3 .\
\>", "Text",
 CellChangeTimes->{{3.9904536391327705`*^9, 3.9904536452437515`*^9}, {
  3.990682566759636*^9, 
  3.99068256781744*^9}},ExpressionUUID->"e5c14535-7fa6-b243-a682-\
e2864d6e6ac2"]
}, Open  ]],

Cell[CellGroupData[{

Cell["4.3", "Subsection",
 CellChangeTimes->{{3.9912367741371098`*^9, 3.9912368162119923`*^9}, {
  3.991237050030262*^9, 
  3.9912370502661705`*^9}},ExpressionUUID->"89abc913-11df-724b-a7fd-\
a47431a546bd"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"RecoverEdges", "[", 
     RowBox[{"A1_", ",", "A2_", ",", "A3_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "p", "}"}], ",", 
      RowBox[{
       RowBox[{"p", "=", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"8", "*", "A1", "*", "A2", "*", "A3"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"p", "/", 
          RowBox[{"(", 
           RowBox[{"2", "*", "A3"}], ")"}]}], ",", 
         RowBox[{"p", "/", 
          RowBox[{"(", 
           RowBox[{"2", "*", "A2"}], ")"}]}], ",", 
         RowBox[{"p", "/", 
          RowBox[{"(", 
           RowBox[{"2", "*", "A1"}], ")"}]}]}], "}"}]}]}], "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{"RecoverEdges", "[", 
  RowBox[{"2", ",", "3", ",", "6"}], "]"}]}], "Input",
 CellChangeTimes->{{3.9912370162655525`*^9, 3.9912370162655525`*^9}},
 CellLabel->"In[25]:=",ExpressionUUID->"bac8ba4c-1fd9-5145-916d-8138f7c3827e"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   SqrtBox["2"], ",", 
   RowBox[{"2", " ", 
    SqrtBox["2"]}], ",", 
   RowBox[{"3", " ", 
    SqrtBox["2"]}]}], "}"}]], "Output",
 CellChangeTimes->{3.9912370180637417`*^9},
 CellLabel->"Out[26]=",ExpressionUUID->"710da76c-eb73-0b46-958f-ad9da46b0c3a"]
}, Open  ]],

Cell["\<\
Each permutation of (A1, A2, A3) from the table in Section 4.2 yields a \
corresponding permutation of (x, y, z), confirming that the six solutions \
found represent six geometrically distinct tetrahedra .\
\>", "Text",
 CellChangeTimes->{{3.9912370808813095`*^9, 
  3.9912371358795643`*^9}},ExpressionUUID->"529de5b8-1730-164a-8cb8-\
4d4b4d4d370b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["4.4 Numerical minimisation", "Subsection",
 CellChangeTimes->{{3.991221813619274*^9, 3.991221814605257*^9}, 
   3.9912218792876987`*^9, {3.991230127363014*^9, 3.9912301386490726`*^9}, {
   3.9912303789258137`*^9, 3.991230379046133*^9}, {3.9912370527679157`*^9, 
   3.991237053047228*^9}},ExpressionUUID->"f84e6924-7c43-cc4a-9ac6-\
85a801a8f517"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"A1", "[", 
    RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"x", "*", "y"}], ")"}], "/", "2"}]}], " "}], "\n", 
 RowBox[{
  RowBox[{"A2", "[", 
   RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"x", "*", "z"}], ")"}], "/", "2"}]}], "\n", 
 RowBox[{
  RowBox[{"A3", "[", 
   RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"y", "*", "z"}], ")"}], "/", "2"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"A4", "[", 
    RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "/", "2"}], ")"}], "*", 
    RowBox[{"Sqrt", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"x", "^", "2"}], "*", 
       RowBox[{"y", "^", "2"}]}], "+", 
      RowBox[{
       RowBox[{"x", "^", "2"}], "*", 
       RowBox[{"z", "^", "2"}]}], "+", 
      RowBox[{
       RowBox[{"y", "^", "2"}], "*", 
       RowBox[{"z", "^", "2"}]}]}], "]"}]}]}], "\[IndentingNewLine]", 
  RowBox[{"(*", "QF", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"QF", "[", 
    RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"A1", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}], "+", 
      RowBox[{"A2", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}], "+", 
      RowBox[{"A3", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}], "+", 
      RowBox[{"A4", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}], "-", "18"}], ")"}], "^", 
    "2"}]}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{"sol", "=", 
  RowBox[{"NMinimize", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"QF", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}], ",", 
      RowBox[{"x", ">", "0"}], ",", 
      RowBox[{"y", ">", "0"}], ",", 
      RowBox[{"z", ">", "0"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "y", ",", "z"}], "}"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.991221874136017*^9, 3.991221874136017*^9}, 
   3.9912219307479763`*^9, {3.991222007567152*^9, 3.9912220309374657`*^9}, {
   3.991230081948139*^9, 3.9912300976937656`*^9}, {3.991230141409546*^9, 
   3.991230152640049*^9}, 3.9912304605295124`*^9, {3.991232103307373*^9, 
   3.991232148585413*^9}, {3.9912365817191334`*^9, 
   3.9912365894101295`*^9}},ExpressionUUID->"084979a5-a285-2146-8a2a-\
63b3af9e08c4"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"7.987314484114992`*^-24", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"x", "\[Rule]", "2.758205060286115`"}], ",", 
     RowBox[{"y", "\[Rule]", "2.758205060286115`"}], ",", 
     RowBox[{"z", "\[Rule]", "2.758205060286115`"}]}], "}"}]}], 
  "}"}]], "Output",
 CellChangeTimes->{3.991230100416918*^9},
 CellLabel->"Out[24]=",ExpressionUUID->"e1477492-0e19-7a4b-989e-682079a2d7c0"]
}, Open  ]],

Cell["\<\
The minimization confirms that the quality function attains a value of \
essentially zero, verifying that real - valued solutions to \
\>", "Text",
 CellChangeTimes->{{3.9912305319171734`*^9, 
  3.991230553080515*^9}},ExpressionUUID->"33bd38b6-d668-944c-9f0d-\
ba412125b2b7"],

Cell[BoxData[
 StyleBox[
  RowBox[{
   RowBox[{
   "A1", " ", "+", " ", "A2", " ", "+", " ", "A3", " ", "+", " ", "A4"}], " ",
    "=", " ", "18."}],
  FontColor->GrayLevel[0]]], "Input",
 CellChangeTimes->{{3.9912305319171734`*^9, 3.991230566743635*^9}, {
  3.991237190443178*^9, 
