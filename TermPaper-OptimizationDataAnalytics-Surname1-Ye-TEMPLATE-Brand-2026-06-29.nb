Cell[TextData[{
 "NMinimize drives the quality function to essentially zero, confirming that \
the total-area constraint can be met exactly ",
 StyleBox["(total = 18)",
  FontWeight->"Bold"],
 ". The optimum is the most symmetric trirectangular tetrahedron ",
 StyleBox["(x = y = z = 2.758)",
  FontWeight->"Bold"],
 ", but its areas are not integers. "
}], "Text",
 CellChangeTimes->{{3.9914397870883865`*^9, 
  3.99143986150902*^9}},ExpressionUUID->"a7af14a7-0c0a-454e-bc39-\
2bdeceb63162"],

Cell[TextData[{
 "Since the continuous problem has infinitely many solutions, NMinimize \
returns only one of them - which is why the discrete search in Section 4.4 is \
the right method: the integer constraint yields the unique solution ",
 StyleBox["(2, 3, 6, 7)",
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{
  3.9914398679124107`*^9},ExpressionUUID->"efe0d08e-a95d-4349-82b8-\
eb098cbd7107"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["5 - Visualization", "Section",
 CellChangeTimes->{{3.6943454921732183`*^9, 3.6943455118916535`*^9}, {
  3.990453661784958*^9, 3.9904536810374985`*^9}, {3.9906837694064903`*^9, 
  3.9906837747675743`*^9}, {3.9913000144700184`*^9, 
  3.991300015440338*^9}},ExpressionUUID->"51446a21-d1e2-4a37-b7a3-\
a9c59539edcb"],

Cell[CellGroupData[{

Cell["5.1 3D Graphic", "Subsection",
 CellChangeTimes->{{3.6551323318137064`*^9, 3.655132346618133*^9}, {
   3.6558834788297663`*^9, 3.655883482105772*^9}, {3.655883581805547*^9, 
   3.655883589683561*^9}, {3.6558837346868153`*^9, 3.655883735919217*^9}, {
   3.694341574232729*^9, 3.694341596852769*^9}, {3.694342244717239*^9, 
   3.694342247462844*^9}, {3.694342333660995*^9, 3.694342343083412*^9}, {
   3.6943424202555304`*^9, 3.694342429299047*^9}, {3.6943424762647333`*^9, 
   3.694342484642213*^9}, {3.694342535512122*^9, 3.694342552269081*^9}, {
   3.6943425832578535`*^9, 3.694342597036641*^9}, {3.694342646046445*^9, 
   3.694342765915301*^9}, {3.694342880577859*^9, 3.694342892973568*^9}, {
   3.920005136849468*^9, 3.9200051373384686`*^9}, 3.9904536885486145`*^9, {
   3.9904537527895145`*^9, 3.9904537585075016`*^9}, {3.9906838105133533`*^9, 
   3.9906838351094856`*^9}, 
   3.9914402603726616`*^9},ExpressionUUID->"f3069855-fa7c-4747-946c-\
9d7721b4e4b4"],

Cell["\<\
The figure shows the tetrahedron corresponding to the solution (2, 3, 6, 7), \
built from the edge lengths x = Sqrt(2), y = 2 Sqrt(2), z = 3 Sqrt(2). \
\>", "Text",
 CellChangeTimes->{{3.991441441388687*^9, 3.99144146313183*^9}, 
   3.9914417632851887`*^9},ExpressionUUID->"b28fb721-8751-0048-b2e0-\
0903a0b0ee33"],

Cell[BoxData[
 RowBox[{
  RowBox[{"x", "=", 
   SqrtBox["2"]}], ",", " ", 
  RowBox[{"y", "=", 
   RowBox[{"2", 
    SqrtBox["2"]}]}], ",", 
  RowBox[{"z", "=", 
   RowBox[{"3", 
    RowBox[{
     SqrtBox["2"], "."}]}]}]}]], "Input",ExpressionUUID->"f289617d-6de6-cb48-\
b030-03b17ca1a4da"],

Cell["\<\
The three faces meeting at the right-angle corner (the origin) are the right \
triangles A1 = 2, A2 = 3 and A3 = 6, and the oblique face opposite the corner \
is A4 = 7. \
\>", "Text",
 CellChangeTimes->{3.9914417716886387`*^9, 
  3.9914419928398952`*^9},ExpressionUUID->"a7e40248-18f9-5e4c-b8f3-\
dc30347eff58"],

Cell["\<\
The graphic is interactive and can be rotated freely to inspect it from any \
angle.\
\>", "Text",
 CellChangeTimes->{
  3.991441998610121*^9},ExpressionUUID->"a7d034a5-7645-aa46-8506-\
593aa1790f42"],

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", "Calculations"}]], "Input",
 CellChangeTimes->{{3.991443115963524*^9, 
  3.991443126354164*^9}},ExpressionUUID->"00ea64d6-249f-e34f-98c7-\
07218e3ddacd"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"x", "=", 
    RowBox[{"Sqrt", "[", "2", "]"}]}], ";", 
   RowBox[{"y", "=", 
    RowBox[{"2", "*", 
     RowBox[{"Sqrt", "[", "2", "]"}]}]}], ";", 
   RowBox[{"z", "=", 
    RowBox[{"3", "*", 
     RowBox[{"Sqrt", "[", "2", "]"}]}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{"Graphics3D", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Opacity", "[", "0.4", "]"}], ",", 
