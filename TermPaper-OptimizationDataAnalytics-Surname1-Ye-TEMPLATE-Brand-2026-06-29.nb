Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SolutionPerSum", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\n", 
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"i", "=", "4"}], ",", 
   RowBox[{"i", "<=", "100"}], ",", 
   RowBox[{"i", "++"}], ",", 
   RowBox[{
    RowBox[{"solutions", "=", 
     RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"A1", "+", "A2", "+", "A3", "+", "A4"}], "==", "i"}], "&&", 
         RowBox[{
          RowBox[{"A4", "^", "2"}], "==", 
          RowBox[{
           RowBox[{"A1", "^", "2"}], "+", 
           RowBox[{"A2", "^", "2"}], "+", 
           RowBox[{"A3", "^", "2"}]}]}]}], ",", 
        RowBox[{"AppendTo", "[", 
         RowBox[{"solutions", ",", 
          RowBox[{"{", 
           RowBox[{"A1", ",", "A2", ",", "A3", ",", "A4"}], "}"}]}], "]"}]}], 
       "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"A1", ",", "1", ",", 
        RowBox[{"i", "-", "3"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"A2", ",", "A1", ",", 
        RowBox[{"i", "-", "3"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"A3", ",", "A2", ",", 
        RowBox[{"i", "-", "3"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"A4", ",", "A3", ",", 
        RowBox[{"i", "-", "3"}]}], "}"}]}], "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"AppendTo", "[", 
     RowBox[{"SolutionPerSum", ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", 
        RowBox[{"Length", "[", "solutions", "]"}]}], "}"}]}], "]"}]}]}], 
  "]"}], "\n", 
 RowBox[{"ListPlot", "[", 
  RowBox[{"SolutionPerSum", ",", 
   RowBox[{"PlotRange", "->", "All"}], ",", 
   RowBox[{"Frame", "->", "True"}], ",", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<Sum i\>\"", ",", "\"\<Quantity of Solutions\>\""}], " ", 
     "}"}]}], ",", 
   RowBox[{"PlotMarkers", "->", "Automatic"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.6551323318137064`*^9, 3.655132346618133*^9}, {
