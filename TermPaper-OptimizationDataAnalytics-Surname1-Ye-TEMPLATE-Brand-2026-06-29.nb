Cell[CellGroupData[{

Cell["7.1 Varying the total area", "Subsection",
 CellChangeTimes->{{3.6943454921732183`*^9, 3.694345497976429*^9}, {
   3.6943455631221437`*^9, 3.694345589018189*^9}, {3.9913175792139378`*^9, 
