Cell["\<\
The plots below show how many integer tetrahedra exist for each total area S: \
the full sweep, an interactive version, the parity structure, and an \
interactive reconstruction of the tetrahedron.\
\>", "Text",
 CellChangeTimes->{{3.991452710317892*^9, 3.991452728199888*^9}, 
   3.9914775128734818`*^9},ExpressionUUID->"5143c310-b55c-ce4b-8922-\
31887f4b75bb"],

