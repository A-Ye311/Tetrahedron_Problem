 RowBox[{" ", 
  RowBox[{
   RowBox[{
    SubscriptBox["A", "1"], "=", 
    FractionBox["xy", "2"]}], ",", " ", 
   RowBox[{
    SubscriptBox["A", "2"], "=", 
    FractionBox["xz", "2"]}], ",", " ", 
   RowBox[{
    SubscriptBox["A", "3"], "=", 
