3039675e656a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    SubscriptBox["A", "1"], "\[Cross]", 
    SubscriptBox["A", "2"], "\[Cross]", 
    SubscriptBox["A", "3"]}], "=", 
   RowBox[{
    RowBox[{
     FractionBox["xy", "2"], "\[Cross]", 
     FractionBox["xz", "2"], "\[Cross]", 
     FractionBox["yz", "2"]}], "=", 
    FractionBox[
     RowBox[{
      SuperscriptBox["x", "2"], 
      SuperscriptBox["y", "2"], 
      SuperscriptBox["z", "2"]}], "8"]}]}], "\n"}]], "Input",
 CellChangeTimes->{{3.6551323318137064`*^9, 3.655132346618133*^9}, {
   3.6558834788297663`*^9, 3.655883482105772*^9}, {3.655883581805547*^9, 
   3.655883589683561*^9}, {3.6558837346868153`*^9, 3.655883735919217*^9}, {
   3.694341574232729*^9, 3.694341596852769*^9}, {3.694342244717239*^9, 
   3.694342247462844*^9}, {3.694342333660995*^9, 3.694342343083412*^9}, {
   3.6943424202555304`*^9, 3.694342429299047*^9}, {3.6943424762647333`*^9, 
   3.694342484642213*^9}, {3.694342535512122*^9, 3.694342552269081*^9}, {
   3.6943425832578535`*^9, 3.694342597036641*^9}, {3.694342646046445*^9, 
   3.694342765915301*^9}, {3.694342880577859*^9, 3.694342892973568*^9}, {
   3.920005136849468*^9, 3.9200051373384686`*^9}, 3.9904530490801907`*^9, {
   3.9906827032540646`*^9, 3.990682704525078*^9}, {3.9906827765189037`*^9, 
   3.9906827886063175`*^9}, 3.9906833458303394`*^9, 3.990683961678097*^9, 
   3.990684125702921*^9},ExpressionUUID->"dd5889fc-b7b8-1e4d-ac00-\
ef278f9515c5"],

Cell["This directly implies :", "Text",
 CellChangeTimes->{{3.9904533680979443`*^9, 
  3.990453374316719*^9}},ExpressionUUID->"331375c1-06b3-d64d-9699-\
03811dec39d2"],

Cell[BoxData[
 RowBox[{"xyz", "=", 
  SqrtBox[
   RowBox[{"8", "\[Cross]", 
    SubscriptBox["A", "1"], "\[Cross]", 
    SubscriptBox["A", "2"], "\[Cross]", 
    SubscriptBox["A", "3"]}]]}]], "Input",
 CellChangeTimes->{{3.9904533788595943`*^9, 
  3.990453433315296*^9}},ExpressionUUID->"70f4aa1f-3c70-9f4b-bd8c-\
b78306e40325"],

Cell["\<\
Once xyz is known, the individual edge lengths can be recovered by dividing \
through the respective face products :\
\>", "Text",
 CellChangeTimes->{{3.990453439516323*^9, 
  3.9904534473939667`*^9}},ExpressionUUID->"71c8bcc5-a571-de40-9358-\
643afde52c40"],

Cell[BoxData[
 RowBox[{
  RowBox[{"x", "=", 
   FractionBox["xyz", "yz"]}], ",", " ", 
  RowBox[{"y", "=", 
   FractionBox["xyz", "xz"]}], ",", " ", 
  RowBox[{"z", "=", 
   FractionBox["xyz", "xy"]}]}]], "Input",
 CellChangeTimes->{{3.9904534630067196`*^9, 3.9904534913117657`*^9}, {
  3.9904535552867146`*^9, 
  3.990453572960682*^9}},ExpressionUUID->"b58ada4c-d645-3043-8399-\
bcc407bd4f64"],

Cell["\<\
This approach avoids solving a full system of equations and reduces the \
problem to a simple division once the areas are known.\
\>", "Text",
 CellChangeTimes->{{3.99045358157992*^9, 3.9904535865098457`*^9}, 
   3.990461608024132*^9},ExpressionUUID->"398fab66-02fc-f545-987f-\
35b93ce3b113"]
}, Open  ]],

Cell[CellGroupData[{

Cell["4. Systematic Search", "Subsection",
 CellChangeTimes->{{3.6943454921732183`*^9, 3.6943455089276485`*^9}, 
   3.9904535966306705`*^9, 
   3.991286405940834*^9},ExpressionUUID->"64d905b6-1c05-4671-a397-\
d9051e682947"],

Cell["\<\
Since A4 is fully determined by A1, A2, and A3 via De Gua\[CloseCurlyQuote]s \
Theorem, the problem reduces to searching all integer triplets (A1, A2, A3) \
and checking whether the resulting A4 is also a natural number and the total \
sum equals 18. To account for all valid arrangements, permutations of the leg \
areas are considered as distinct solutions. This search is implemented in \
Mathematica as follows:\
\>", "Text",
 CellChangeTimes->{{3.6551323318137064`*^9, 3.655132346618133*^9}, {
  3.6558834788297663`*^9, 3.655883482105772*^9}, {3.655883581805547*^9, 
  3.655883589683561*^9}, {3.6558837346868153`*^9, 3.655883735919217*^9}, {
  3.694341574232729*^9, 3.694341596852769*^9}, {3.694342244717239*^9, 
  3.694342247462844*^9}, {3.694342333660995*^9, 3.694342343083412*^9}, {
  3.6943424202555304`*^9, 3.694342429299047*^9}, {3.6943424762647333`*^9, 
  3.694342484642213*^9}, {3.694342535512122*^9, 3.694342552269081*^9}, {
  3.6943425832578535`*^9, 3.694342597036641*^9}, {3.694342646046445*^9, 
  3.694342765915301*^9}, {3.694342880577859*^9, 3.694342892973568*^9}, {
  3.920005136849468*^9, 3.9200051373384686`*^9}, {3.9904536031079235`*^9, 
  3.9904536133700294`*^9}},ExpressionUUID->"720fd0cf-3b1a-5641-91db-\
187a96969d99"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{" ", 
  RowBox[{
   RowBox[{
    RowBox[{"solutions", "=", 
     RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"A4", "=", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{"A1", "^", "2"}], "+", 
          RowBox[{"A2", "^", "2"}], "+", 
          RowBox[{"A3", "^", "2"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"IntegerQ", "[", "A4", "]"}], "&&", 
          RowBox[{
           RowBox[{"A1", "+", "A2", "+", "A3", "+", "A4"}], "==", "18"}]}], ",", 
         RowBox[{"AppendTo", "[", 
          RowBox[{"solutions", ",", 
           RowBox[{"{", 
            RowBox[{"A1", ",", "A2", ",", "A3", ",", "A4"}], "}"}]}], "]"}]}],
         "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"A1", ",", "1", ",", "15"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"A2", ",", "1", ",", "15"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"A3", ",", "1", ",", "15"}], "}"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"Grid", "[", 
    RowBox[{
     RowBox[{"Prepend", "[", 
      RowBox[{"solutions", ",", 
       RowBox[{"{", 
        RowBox[{"\"\<A1\>\"", ",", "\"\<A2\>\"", ",", "\"\<A3\>\"", 
         ",", "\"\<A4\>\""}], "}"}]}], "]"}], ",", 
     RowBox[{"Frame", "->", "All"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{
  3.6943456316374636`*^9, 3.990453619827881*^9, {3.9906829215736275`*^9, 
   3.9906829351026287`*^9}, {3.9912867033839455`*^9, 
   3.9912867062242737`*^9}},ExpressionUUID->"63973c09-62b7-45ce-8eee-\
a870279ee06a"],

Cell[BoxData[
 TagBox[GridBox[{
    {"\<\"A1\"\>", "\<\"A2\"\>", "\<\"A3\"\>", "\<\"A4\"\>"},
    {"2", "3", "6", "7"},
    {"2", "6", "3", "7"},
    {"3", "2", "6", "7"},
    {"3", "6", "2", "7"},
    {"6", "2", "3", "7"},
    {"6", "3", "2", "7"}
   },
   AutoDelete->False,
   GridBoxFrame->{"Columns" -> {{True}}, "Rows" -> {{True}}},
   GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
  "Grid"]], "Output",
 CellChangeTimes->{3.990453628937849*^9},
 CellLabel->"Out[3]=",ExpressionUUID->"c4d54ae6-24d7-5248-a6b1-7783ab899168"]
}, Open  ]],

Cell["\<\
Each permutation corresponds to a different assignment of the edge lengths x, \
y, z and therefore a geometrically distinct tetrahedron, even though the set \
of surface areas remains identical . A4 remains 7 in all cases since De Gua' \
s Theorem is symmetric in A1, A2, A3 .\
\>", "Text",
 CellChangeTimes->{{3.9904536391327705`*^9, 3.9904536452437515`*^9}, {
  3.990682566759636*^9, 
  3.99068256781744*^9}},ExpressionUUID->"e5c14535-7fa6-b243-a682-\
e2864d6e6ac2"]
}, Open  ]],

Cell[CellGroupData[{

Cell["4. ", "Subsection",
 CellChangeTimes->{{3.991221813619274*^9, 3.991221814605257*^9}, 
   3.9912218792876987`*^9, {3.991230127363014*^9, 3.9912301386490726`*^9}, {
   3.9912303789258137`*^9, 3.991230379046133*^9}, {3.9912370527679157`*^9, 
   3.991237053047228*^9}, {3.991286151189535*^9, 3.991286151319729*^9}, 
   3.991286411325926*^9, {3.9912867597496223`*^9, 
   3.9912867616588573`*^9}},ExpressionUUID->"f84e6924-7c43-cc4a-9ac6-\
85a801a8f517"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"A1", "[", 
    RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"x", "*", "y"}], ")"}], "/", "2"}]}], " "}], "\n", 
 RowBox[{
  RowBox[{"A2", "[", 
   RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"x", "*", "z"}], ")"}], "/", "2"}]}], "\n", 
 RowBox[{
  RowBox[{"A3", "[", 
   RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"y", "*", "z"}], ")"}], "/", "2"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"A4", "[", 
    RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "/", "2"}], ")"}], "*", 
    RowBox[{"Sqrt", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"x", "^", "2"}], "*", 
       RowBox[{"y", "^", "2"}]}], "+", 
      RowBox[{
       RowBox[{"x", "^", "2"}], "*", 
       RowBox[{"z", "^", "2"}]}], "+", 
      RowBox[{
       RowBox[{"y", "^", "2"}], "*", 
       RowBox[{"z", "^", "2"}]}]}], "]"}]}]}], "\[IndentingNewLine]", 
  RowBox[{"(*", "QF", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"QF", "[", 
    RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"A1", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}], "+", 
      RowBox[{"A2", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}], "+", 
      RowBox[{"A3", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}], "+", 
      RowBox[{"A4", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}], "-", "18"}], ")"}], "^", 
    "2"}]}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{"sol", "=", 
  RowBox[{"NMinimize", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"QF", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}], ",", 
      RowBox[{"x", ">", "0"}], ",", 
      RowBox[{"y", ">", "0"}], ",", 
      RowBox[{"z", ">", "0"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "y", ",", "z"}], "}"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.991221874136017*^9, 3.991221874136017*^9}, 
   3.9912219307479763`*^9, {3.991222007567152*^9, 3.9912220309374657`*^9}, {
   3.991230081948139*^9, 3.9912300976937656`*^9}, {3.991230141409546*^9, 
   3.991230152640049*^9}, 3.9912304605295124`*^9, {3.991232103307373*^9, 
   3.991232148585413*^9}, {3.9912365817191334`*^9, 
   3.9912365894101295`*^9}},ExpressionUUID->"084979a5-a285-2146-8a2a-\
63b3af9e08c4"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"7.987314484114992`*^-24", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"x", "\[Rule]", "2.758205060286115`"}], ",", 
     RowBox[{"y", "\[Rule]", "2.758205060286115`"}], ",", 
