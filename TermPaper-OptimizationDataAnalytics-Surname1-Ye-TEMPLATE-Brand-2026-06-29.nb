   3.991299987150076*^9}},ExpressionUUID->"c84ad9d9-f16d-4ebd-becc-\
c5897e98c089"],

Cell[TextData[{
 "This report addresses the ",
 StyleBox["\[OpenCurlyDoubleQuote]Tetrahedron Problem : finding the four \
triangular face areas of a tetrahedron whose total surface area is 18 units, \
each area being a natural number.\[CloseCurlyDoubleQuote]",
  FontWeight->"Bold"]
}], "Text",
 CellChangeTimes->{{3.6551323318137064`*^9, 3.655132346618133*^9}, {
   3.6558834788297663`*^9, 3.655883482105772*^9}, {3.655883581805547*^9, 
   3.655883589683561*^9}, {3.6558837346868153`*^9, 3.655883735919217*^9}, {
   3.694341574232729*^9, 3.694341596852769*^9}, {3.694342244717239*^9, 
   3.694342247462844*^9}, {3.694342333660995*^9, 3.694342343083412*^9}, {
   3.6943424202555304`*^9, 3.694342429299047*^9}, {3.6943424762647333`*^9, 
   3.694342484642213*^9}, {3.694342535512122*^9, 3.694342552269081*^9}, {
   3.6943425832578535`*^9, 3.694342597036641*^9}, {3.694342646046445*^9, 
   3.694342765915301*^9}, {3.694342880577859*^9, 3.694342892973568*^9}, {
   3.920005136849468*^9, 3.9200051373384686`*^9}, {3.9913021212330475`*^9, 
   3.99130230246673*^9}, {3.9913023534408855`*^9, 3.9913023616517124`*^9}, {
   3.991303105988222*^9, 3.9913031107691383`*^9}, {3.9913032799466743`*^9, 
   3.991303280671633*^9}, {3.991304150350624*^9, 3.9913041521670666`*^9}, 
   3.991437139234398*^9, {3.991437280161831*^9, 3.991437289418751*^9}, {
   3.991437528991617*^9, 
   3.9914375620192356`*^9}},ExpressionUUID->"cb0726f4-594f-43e4-8e77-\
5d99a6d9f22b"],

Cell["\<\
We model a trirectangular tetrahedron, whose three faces meeting at the \
right-angled vertex have areas\
\>", "Text",
 CellChangeTimes->{
  3.9914371619650116`*^9},ExpressionUUID->"7c7ac270-f696-2747-acaf-\
caa0fdd12b7f"],

Cell[BoxData[
 RowBox[{
  FractionBox["xy", "2"], ",", 
  RowBox[{
   FractionBox["xz", "2"], "and", 
   FractionBox["yz", "2"]}]}]], "Input",
 CellChangeTimes->{{3.9914369966868935`*^9, 3.9914369966868935`*^9}, {
  3.991437071530319*^9, 
  3.991437120740633*^9}},ExpressionUUID->"d1992e02-d2bf-6b4b-9f66-\
fb59aaa3d51d"],

Cell[TextData[{
 "while the fourth face obeys De ",
 StyleBox["Gua\[CloseCurlyQuote]s",
  IgnoreSpellCheck->True],
 " theorem"
}], "Text",
 CellChangeTimes->{
  3.991437193941334*^9},ExpressionUUID->"03054043-f5ac-da4f-a7d4-\
defafd5356dd"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubsuperscriptBox["A", "1", "2"], "+", 
   SubsuperscriptBox["A", "2", "2"], "+", 
   SubsuperscriptBox["A", "3", "2"]}], "=", 
  SubsuperscriptBox["A", "4", "2"]}]], "Input",ExpressionUUID->"42622c00-5e8e-\
6a42-ae24-1f83642ee4de"],

Cell["\<\
Minimizing the quality function to zero enforces the total-area target S, and \
we evaluate this systematically for every integer target from S = 4 to S = \
100. For the required total S = 18, the search returns a single solution (up \
to permutation): the face areas (2, 3, 6, 7), with edges: \
\>", "Text",
 CellChangeTimes->{
  3.991437315411907*^9, {3.9914373833297462`*^9, 
   3.991437383683367*^9}},ExpressionUUID->"76b9cee5-3f05-7b44-a564-\
4f3b50a5f903"],

Cell[BoxData[
 RowBox[{
  RowBox[{"x", "=", 
   SqrtBox["2"]}], ",", " ", 
  RowBox[{"y", "=", 
   RowBox[{"2", 
    SqrtBox["2"]}]}], ",", 
  RowBox[{"z", "=", 
   RowBox[{"3", 
    RowBox[{
     SqrtBox["2"], "."}]}]}]}]], "Input",
 CellChangeTimes->{{3.9914373970473404`*^9, 3.991437403802847*^9}, {
  3.9914374715936546`*^9, 
  3.991437513424204*^9}},ExpressionUUID->"da840adb-40c7-2449-9932-\
71c2737faf6f"],

Cell["\<\
All computations and visualizations were carried out in Wolfram Mathematica.\
\>", "Text",
 CellChangeTimes->{
  3.991437536515524*^9},ExpressionUUID->"1c235a5e-c0b9-0247-96d5-\
295d62a537fb"]
}, Open  ]],

Cell[CellGroupData[{

Cell["2 - Introduction", "Section",
 PageBreakAbove->True,
 CellChangeTimes->{{3.694341537930465*^9, 3.694341550254487*^9}, {
   3.694342355079833*^9, 3.694342363410248*^9}, 3.6943428651189747`*^9, {
   3.6943430193857985`*^9, 3.694343019923829*^9}, {3.6943431695433865`*^9, 
   3.694343174763685*^9}, 3.694345439835127*^9, 3.920005199087162*^9, 
   3.99045269259453*^9, {3.99129998439373*^9, 
   3.9912999845550137`*^9}},ExpressionUUID->"cdc5618b-ff33-4f5c-8ceb-\
21a3425e82dc"],

Cell[TextData[{
 "This report was prepared as part of the course ",
 StyleBox["\[OpenCurlyDoubleQuote]Optimization and Simulation\
\[CloseCurlyDoubleQuote]",
  FontWeight->"Bold"],
 ". \n\nThe problem at hand serves as a practical example of how mathematical \
optimization techniques and computational tools can be combined to solve \
geometric problems systematically.\n\nA right-angle tetrahedron is a \
three-dimensional geometric object consisting of four triangular faces, where \
three of the four faces meet at a common vertex at right angles to one \
another. \n\nThis structure is the natural three-dimensional extension of a \
right-angle triangle. "
}], "Text",
 CellChangeTimes->{{3.6551323318137064`*^9, 3.655132346618133*^9}, {
  3.6558834788297663`*^9, 3.655883482105772*^9}, {3.655883581805547*^9, 
  3.655883589683561*^9}, {3.6558837346868153`*^9, 3.655883735919217*^9}, {
  3.694341574232729*^9, 3.694341596852769*^9}, {3.694342244717239*^9, 
  3.694342247462844*^9}, {3.694342333660995*^9, 3.694342343083412*^9}, {
  3.6943424202555304`*^9, 3.694342429299047*^9}, {3.6943424762647333`*^9, 
  3.694342484642213*^9}, {3.694342535512122*^9, 3.694342552269081*^9}, {
  3.6943425832578535`*^9, 3.694342597036641*^9}, {3.694342646046445*^9, 
  3.694342765915301*^9}, {3.694342880577859*^9, 3.694342892973568*^9}, {
  3.920005136849468*^9, 3.9200051373384686`*^9}, {3.990451867152336*^9, 
  3.990451869706068*^9}, {3.990452411325676*^9, 3.990452415695072*^9}, {
  3.990684625898201*^9, 3.9906846513652973`*^9}, {3.991299840024355*^9, 
  3.9912998828953743`*^9}},ExpressionUUID->"5c85260f-b5be-694f-b4cd-\
b8ee9ff9cd14"]
}, Open  ]],

Cell[CellGroupData[{

Cell["3 - Problem Statement", "Section",
 PageBreakAbove->True,
 CellChangeTimes->{{3.694341537930465*^9, 3.694341550254487*^9}, {
   3.694342355079833*^9, 3.694342363410248*^9}, 3.6943428651189747`*^9, {
   3.6943430193857985`*^9, 3.694343019923829*^9}, {3.6943431695433865`*^9, 
   3.694343174763685*^9}, 3.694345448914343*^9, 3.920005205066906*^9, {
   3.99129998115909*^9, 
   3.9912999813194904`*^9}},ExpressionUUID->"82473837-570c-4bf9-b27a-\
b88eb03e0623"],

Cell["\<\
Let a right-angle tetrahedron with edge lengths x, y, z > 0 be given. The \
three faces adjacent to the right-angle vertex have the following surface \
areas:\
\>", "Text",
 CellChangeTimes->{{3.6551323318137064`*^9, 3.655132346618133*^9}, {
   3.6558834788297663`*^9, 3.655883482105772*^9}, {3.655883581805547*^9, 
   3.655883589683561*^9}, {3.6558837346868153`*^9, 3.655883735919217*^9}, {
   3.694341574232729*^9, 3.694341596852769*^9}, {3.694342244717239*^9, 
   3.694342247462844*^9}, {3.694342333660995*^9, 3.694342343083412*^9}, {
   3.6943424202555304`*^9, 3.694342429299047*^9}, {3.6943424762647333`*^9, 
   3.694342484642213*^9}, {3.694342535512122*^9, 3.694342552269081*^9}, {
   3.6943425832578535`*^9, 3.694342597036641*^9}, {3.694342646046445*^9, 
   3.694342765915301*^9}, {3.694342880577859*^9, 3.694342892973568*^9}, {
   3.920005136849468*^9, 3.9200051373384686`*^9}, 
   3.990451959927845*^9},ExpressionUUID->"9fa5a7f9-5403-1c4d-b45f-\
fc3fdf894aee"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{
   RowBox[{
    SubscriptBox["A", "1"], "=", 
    FractionBox["xy", "2"]}], ",", " ", 
   RowBox[{
    SubscriptBox["A", "2"], "=", 
    FractionBox["xz", "2"]}], ",", " ", 
   RowBox[{
    SubscriptBox["A", "3"], "=", 
    FractionBox["yz", "2"]}]}]}]], "Input",
 CellChangeTimes->{
  3.694345762940171*^9, {3.9904519657512856`*^9, 3.9904520380841675`*^9}, {
   3.9913028276804276`*^9, 
   3.991302828325672*^9}},ExpressionUUID->"25190add-2924-467f-8bf7-\
975d689e5f07"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{
   SubscriptBox["A", "4"], "=", 
   FractionBox[
    SqrtBox[
     RowBox[{
      RowBox[{
       SuperscriptBox["x", "2"], 
       SuperscriptBox["y", "2"]}], "+", 
      RowBox[{
       SuperscriptBox["x", "2"], 
       SuperscriptBox["z", "2"]}], "+", 
      RowBox[{
       SuperscriptBox["y", "2"], 
       SuperscriptBox["z", "2"]}]}]], "2"]}]}]], "Input",
 CellChangeTimes->{{3.990452049130247*^9, 3.9904520520463448`*^9}, 
   3.990461602439844*^9, {3.9906832812104435`*^9, 3.9906833016273193`*^9}, 
   3.990684154159897*^9, 
   3.99130282475062*^9},ExpressionUUID->"d0827fd6-3b96-4547-9abf-\
3467114ac4c1"],

Cell["\<\
It can be shown that these four areas satisfy the following relationship:\
\>", "Text",
 CellChangeTimes->{{3.990452360340946*^9, 3.9904523648229504`*^9}, 
   3.99046159953784*^9},ExpressionUUID->"1f11e8a4-1f6a-eb4a-b68e-\
d0d88be7c629"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{
   RowBox[{
    SubsuperscriptBox["A", "1", "2"], "+", 
    SubsuperscriptBox["A", "2", "2"], "+", 
    SubsuperscriptBox["A", "3", "2"]}], "=", 
   SubsuperscriptBox["A", "4", "2"]}]}]], "Input",
 CellChangeTimes->{{3.9904523726403866`*^9, 3.990452383166353*^9}, {
   3.9904524299174633`*^9, 3.9904524798602295`*^9}, 
   3.991302820730669*^9},ExpressionUUID->"3a67858a-a745-cd4e-bf07-\
1051fb315b2c"],

Cell[TextData[{
 "This relationship is known as De ",
 StyleBox["Gua\[CloseCurlyQuote]s",
  IgnoreSpellCheck->True],
 " theorem, the three-dimensional analogue of the Pythagorean theorem. It \
shows that A4 is fully determined once A1, A2 and A3 are fixed, so the four \
face areas form a single dependent system rather than four free variables.\n\n\
Our constraints: "
}], "Text",
 CellChangeTimes->{{3.990452487888756*^9, 3.9904524971572075`*^9}, 
   3.990461595403324*^9, {3.9906830173495274`*^9, 3.9906830298910847`*^9}, {
   3.9906832285108643`*^9, 3.99068322894475*^9}, {3.990683265632801*^9, 
   3.9906832719112263`*^9}, {3.9906839107205906`*^9, 3.990683917779646*^9}, {
   3.991302761332239*^9, 3.9913027782983456`*^9}, {3.9913029778571568`*^9, 
   3.9913030084518814`*^9}},ExpressionUUID->"35b45854-3018-9941-af73-\
259516ab44b7"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{
   RowBox[{
    RowBox[{
     SubscriptBox["A", "1"], "+", 
     SubscriptBox["A", "2"], "+", 
     SubscriptBox["A", "3"], "+", 
     SubscriptBox["A", "4"]}], " ", "=", " ", "18"}], "\[IndentingNewLine]", 
   "\t", 
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["A", "1"], "\[Epsilon]", " ", "\:2115", " ", "for", " ", 
      "i"}], "=", "1"}], ",", "2", ",", "3", ",", "4"}]}]}]], "Input",
 CellChangeTimes->{{3.9904525072496223`*^9, 3.990452546243204*^9}, {
  3.990452929776308*^9, 3.990452962812275*^9}, {3.991302815730465*^9, 
  3.991302817480419*^9}},ExpressionUUID->"b98937ea-69d2-fa45-b660-\
7534763fece7"],

Cell["\<\
The problem therefore reduces to finding all integer triplets (A1, A2, A3) \
such that the resulting A4 is also a natural number and the total sum equals \
18.\
\>", "Text",
 CellChangeTimes->{{3.990452977564764*^9, 3.990452983694853*^9}, 
   3.9913028475147533`*^9, 
   3.991303020649431*^9},ExpressionUUID->"729ceee0-54fc-f647-b396-\
eb7ac3166527"],

Cell["\<\
Based on these conditions, we define the following quality function, which \
must be minimized to zero:\
\>", "Text",
 CellChangeTimes->{{3.9906843591271286`*^9, 3.990684378423479*^9}, {
  3.990684737170374*^9, 3.9906847544678955`*^9}, {3.9912861709361877`*^9, 
  3.9912861720278053`*^9}, {3.9913028677524757`*^9, 3.9913029181468678`*^9}, {
  3.9913030121171207`*^9, 
  3.991303015430853*^9}},ExpressionUUID->"881540b2-1e3a-da4c-b759-\
56a8c37e667b"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{
   RowBox[{"QF", "=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["A", "1"], "+", 
        SubscriptBox["A", "2"], "+", 
        SubscriptBox["A", "3"], "+", 
        SubscriptBox["A", "4"], " ", "-", "18"}], ")"}], "2"], " ", "=", " ", 
     "0"}]}], "\[IndentingNewLine]", "\t", 
   RowBox[{"QF", " ", "=", " ", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["A", "1"], "+", 
        SubscriptBox["A", "2"], "+", 
        SubscriptBox["A", "3"], " ", "+", 
        SqrtBox[
         RowBox[{
          SubsuperscriptBox["A", "1", "2"], "+", 
          SubsuperscriptBox["A", "2", "2"], "+", 
          SubsuperscriptBox["A", "3", "2"]}]], "-", "18"}], ")"}], "2"], "=", 
     " ", "0"}]}], "\[IndentingNewLine]", "\t", 
   RowBox[{
    RowBox[{"QF", 
     RowBox[{"(", 
      RowBox[{"x", ",", "y", ",", "z"}], ")"}]}], "=", " ", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        FractionBox["xy", "2"], "+", 
        FractionBox["xz", "2"], "+", 
        FractionBox["yz", "2"], " ", "+", " ", 
        FractionBox[
         SqrtBox[
          RowBox[{
           RowBox[{
            SuperscriptBox["x", "2"], 
            SuperscriptBox["y", "2"]}], "+", 
           RowBox[{
            SuperscriptBox["x", "2"], 
            SuperscriptBox["z", "2"]}], "+", 
           RowBox[{
            SuperscriptBox["y", "2"], 
            SuperscriptBox["z", "2"]}]}]], "2"], " ", "-", "18"}], ")"}], 
      "2"], " ", "=", " ", "0"}]}]}]}]], "Input",
 CellChangeTimes->{{3.9912217155701447`*^9, 3.991221802499235*^9}, {
  3.99122191997538*^9, 3.99122192185968*^9}, {3.9913029111623726`*^9, 
  3.9913029131977577`*^9}},ExpressionUUID->"1a05b1af-407d-304c-81a2-\
b82788b74035"],

Cell["\<\
The required total is 18, but the same quality function is evaluated for \
general targets S in Section 6, in order to study how the set of integer \
solutions depends on the total-area budget.\
\>", "Text",
 CellChangeTimes->{{3.9913030599303207`*^9, 
  3.9913030701823425`*^9}},ExpressionUUID->"887afe31-ae24-6d45-b262-\
ffe52d925c9c"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "4 - Solution",
 Cell[BoxData[""], "Input",
  CellChangeTimes->{{3.9906839291701984`*^9, 3.9906839335792427`*^9}, {
   3.9906840387992573`*^9, 3.990684115246788*^9}, {3.990684223587511*^9, 
   3.9906843393951073`*^9}},ExpressionUUID->
  "f47640dd-ba74-8849-8e2f-fb4b9945262a"]
}], "Section",
 PageBreakAbove->True,
 CellChangeTimes->{{3.694341537930465*^9, 3.694341550254487*^9}, {
   3.694342355079833*^9, 3.694342363410248*^9}, 3.6943428651189747`*^9, {
   3.6943430193857985`*^9, 3.694343019923829*^9}, {3.6943431695433865`*^9, 
   3.694343174763685*^9}, 3.694345457572358*^9, 3.9200052107218494`*^9, 
   3.9906839211539326`*^9, 3.9906840327960777`*^9, {3.990684425691986*^9, 
   3.9906844292832603`*^9}, {3.9912218087302246`*^9, 
   3.9912218097970066`*^9}, {3.991299977552162*^9, 
   3.991299977776375*^9}},ExpressionUUID->"e0ce679d-baae-4e3f-955a-\
2426a5ad958a"],

Cell[CellGroupData[{

Cell["4.1 Constraints", "Subsection",
 CellChangeTimes->{{3.9912863084491596`*^9, 3.9912863317361946`*^9}, 
   3.991286393110281*^9, {3.9912864313417435`*^9, 3.9912864318339024`*^9}, 
   3.991299993040222*^9},ExpressionUUID->"a4ec537c-5aeb-8e4d-a215-\
fc23444eefbe"],

Cell["The problem is subject to two constraints:", "Text",
 CellChangeTimes->{{3.991304057503212*^9, 3.9913040601725845`*^9}, {
  3.991304234757761*^9, 3.9913042590433655`*^9}, {3.991304939495865*^9, 
  3.99130494122287*^9}, {3.99131258234671*^9, 3.9913126185656624`*^9}, {
  3.9913126945223656`*^9, 
  3.9913127440168667`*^9}},ExpressionUUID->"d887f889-d87e-134f-8ec5-\
5d5e985f7f72"],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["First",
  FontWeight->"Bold"],
 ", the four face areas must sum to the prescribed total of 18 area units. "
}], "Item",
 CellChangeTimes->{
  3.991312622724415*^9, {3.9913127267275906`*^9, 3.991312728688284*^9}, 
   3.9914377308578568`*^9, {3.991437763160614*^9, 3.9914377656184044`*^9}, {
   3.9914377994403267`*^9, 3.991437799699095*^9}, {3.991442186762171*^9, 
   3.9914421878522816`*^9}},ExpressionUUID->"ee718b03-75cb-9a49-bfd7-\
654bfe0a874e"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{
   RowBox[{
    SubscriptBox["A", "1"], "+", 
    SubscriptBox["A", "2"], "+", 
    SubscriptBox["A", "3"], "+", 
    SubscriptBox["A", "4"]}], " ", "=", " ", "18"}]}]], "Input",
 CellChangeTimes->{{3.9913126801910458`*^9, 3.9913126835109673`*^9}, 
   3.9913127307990093`*^9, 3.9914377332100697`*^9, 
   3.9914377688904552`*^9},ExpressionUUID->"9c81acdb-3a3d-7845-a248-\
078371dd7b5f"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Second",
  FontWeight->"Bold"],
 ", each face area must be a natural number. "
}], "Item",
 CellChangeTimes->{
  3.9913126991551495`*^9, 3.9914377349088173`*^9, {3.991437771581547*^9, 
   3.991437796495178*^9}},ExpressionUUID->"f4367371-2a08-b341-af2b-\
9e49dcfd7ed5"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{
   RowBox[{
    RowBox[{
     SubscriptBox["A", "1"], "\[Epsilon]", " ", "\:2115", " ", "for", " ", 
     "i"}], "=", "1"}], ",", "2", ",", "3", ",", "4"}]}]], "Input",
 CellChangeTimes->{3.9913127326360683`*^9, 3.991437736501356*^9, 
  3.9914377774368477`*^9},ExpressionUUID->"8f6a2b35-ad5f-6e4d-80ed-\
cc6f742f17e2"]
}, Open  ]],

Cell[TextData[{
 "Combined with De ",
 StyleBox["Gua\[CloseCurlyQuote]s",
  IgnoreSpellCheck->True],
 " relation from Section 3"
}], "Text",
 CellChangeTimes->{
  3.991312722856058*^9, {3.991437700166559*^9, 3.9914377430141335`*^9}, 
   3.9914377796136417`*^9},ExpressionUUID->"f630584c-f1ca-b44c-8854-\
954119175195"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{
   RowBox[{
    RowBox[{
     SubsuperscriptBox["A", "1", "2"], "+", 
     SubsuperscriptBox["A", "2", "2"], "+", 
     SubsuperscriptBox["A", "3", "2"]}], "=", 
    SubsuperscriptBox["A", "4", "2"]}], ","}]}]], "Input",
 CellChangeTimes->{{3.9914377163808765`*^9, 3.9914377453231697`*^9}, 
   3.9914377826452713`*^9},ExpressionUUID->"64078eaa-f360-3c46-8d39-\
1bc2320dd2ce"],

Cell["These conditions define the set of admissible solutions.", "Text",
 CellChangeTimes->{
  3.9914377213073864`*^9, {3.9914377854876575`*^9, 
   3.991437788264269*^9}},ExpressionUUID->"c5467223-130a-8a49-8e1d-\
6449b1e8aa22"]
}, Open  ]],

Cell[CellGroupData[{

Cell["4.2 Quality Function", "Subsection",
 CellChangeTimes->{{3.9912863404590282`*^9, 3.99128635267029*^9}, {
   3.991286433972349*^9, 3.991286434376028*^9}, 3.991299919251314*^9, 
   3.9912999951252117`*^9},ExpressionUUID->"9c4e0287-e2bc-c34d-9462-\
b196788f33d6"],

Cell[TextData[{
 "To express the total-area condition as an optimization objective, we define \
a quality function QF that ",
 StyleBox["squares the deviation of the total area from 18",
  FontWeight->"Bold"],
 ". This function is always non-negative and equals zero exactly when the \
constraint A1 + A2 + A3 + A4 = 18 holds. Minimizing QF to zero is therefore \
equivalent to satisfying the constraint."
}], "Text",
 CellChangeTimes->{{3.9913052806094055`*^9, 3.991305306862726*^9}, {
  3.991305363670595*^9, 
  3.9913053647457867`*^9}},ExpressionUUID->"4c268f6a-40f2-1e49-8a9d-\
7331651978e5"],

Cell[BoxData[{
 RowBox[{"QF", "=", 
  RowBox[{
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["A", "1"], "+", 
      SubscriptBox["A", "2"], "+", 
      SubscriptBox["A", "3"], "+", 
      SubscriptBox["A", "4"], " ", "-", "18"}], ")"}], "2"], " ", "=", " ", 
   "0"}]}], "\[IndentingNewLine]", 
 RowBox[{"QF", " ", "=", " ", 
  RowBox[{
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["A", "1"], "+", 
      SubscriptBox["A", "2"], "+", 
      SubscriptBox["A", "3"], " ", "+", 
      SqrtBox[
       RowBox[{
        SubsuperscriptBox["A", "1", "2"], "+", 
        SubsuperscriptBox["A", "2", "2"], "+", 
        SubsuperscriptBox["A", "3", "2"]}]], "-", "18"}], ")"}], "2"], "=", 
   " ", "0"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"QF", 
   RowBox[{"(", 
    RowBox[{"x", ",", "y", ",", "z"}], ")"}]}], "=", " ", 
  RowBox[{
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      FractionBox["xy", "2"], "+", 
      FractionBox["xz", "2"], "+", 
      FractionBox["yz", "2"], " ", "+", " ", 
      FractionBox[
       SqrtBox[
        RowBox[{
         RowBox[{
          SuperscriptBox["x", "2"], 
          SuperscriptBox["y", "2"]}], "+", 
         RowBox[{
          SuperscriptBox["x", "2"], 
          SuperscriptBox["z", "2"]}], "+", 
         RowBox[{
          SuperscriptBox["y", "2"], 
          SuperscriptBox["z", "2"]}]}]], "2"], " ", "-", "18"}], ")"}], "2"], 
   " ", "=", " ", "0"}]}]}], "Input",ExpressionUUID->"ed5bafb5-74d4-954c-b4f9-\
2de2abb1b1d7"]
}, Open  ]],

Cell[CellGroupData[{

Cell["4.3 Rearrange mathematical formula", "Subsection",
 CellChangeTimes->{{3.9906829694227276`*^9, 3.9906829885139256`*^9}, {
   3.990683240045719*^9, 3.990683253407587*^9}, 3.9906844331032734`*^9, 
   3.9912864035271473`*^9, 
   3.991299999711975*^9},ExpressionUUID->"fab2e7da-43b9-4640-a576-\
3039675e656a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox["A", "1"], "\[Cross]", 
   SubscriptBox["A", "2"], "\[Cross]", 
   SubscriptBox["A", "3"]}], "=", 
  RowBox[{
   RowBox[{
    FractionBox["xy", "2"], "\[Cross]", 
    FractionBox["xz", "2"], "\[Cross]", 
    FractionBox["yz", "2"]}], "=", 
   FractionBox[
    RowBox[{
     SuperscriptBox["x", "2"], 
     SuperscriptBox["y", "2"], 
     SuperscriptBox["z", "2"]}], "8"]}]}]], "Input",
 CellChangeTimes->{{3.6551323318137064`*^9, 3.655132346618133*^9}, {
   3.6558834788297663`*^9, 3.655883482105772*^9}, {3.655883581805547*^9, 
   3.655883589683561*^9}, {3.6558837346868153`*^9, 3.655883735919217*^9}, {
   3.694341574232729*^9, 3.694341596852769*^9}, {3.694342244717239*^9, 
   3.694342247462844*^9}, {3.694342333660995*^9, 3.694342343083412*^9}, {
   3.6943424202555304`*^9, 3.694342429299047*^9}, {3.6943424762647333`*^9, 
   3.694342484642213*^9}, {3.694342535512122*^9, 3.694342552269081*^9}, {
   3.6943425832578535`*^9, 3.694342597036641*^9}, {3.694342646046445*^9, 
   3.694342765915301*^9}, {3.694342880577859*^9, 3.694342892973568*^9}, {
   3.920005136849468*^9, 3.9200051373384686`*^9}, 3.9904530490801907`*^9, {
   3.9906827032540646`*^9, 3.990682704525078*^9}, {3.9906827765189037`*^9, 
   3.9906827886063175`*^9}, 3.9906833458303394`*^9, 3.990683961678097*^9, 
   3.990684125702921*^9, 
   3.991437850538965*^9},ExpressionUUID->"dd5889fc-b7b8-1e4d-ac00-\
ef278f9515c5"],

Cell["This directly implies :", "Text",
 CellChangeTimes->{{3.9904533680979443`*^9, 
  3.990453374316719*^9}},ExpressionUUID->"331375c1-06b3-d64d-9699-\
03811dec39d2"],

Cell[BoxData[
 RowBox[{"xyz", "=", 
  SqrtBox[
   RowBox[{"8", "\[Cross]", 
    SubscriptBox["A", "1"], "\[Cross]", 
    SubscriptBox["A", "2"], "\[Cross]", 
    SubscriptBox["A", "3"]}]]}]], "Input",
 CellChangeTimes->{{3.9904533788595943`*^9, 
  3.990453433315296*^9}},ExpressionUUID->"70f4aa1f-3c70-9f4b-bd8c-\
b78306e40325"],

Cell[TextData[{
 "Once ",
 StyleBox["xyz",
  IgnoreSpellCheck->True],
 " is known, the individual edge lengths can be recovered by dividing through \
the respective face products :"
}], "Text",
 CellChangeTimes->{{3.990453439516323*^9, 
  3.9904534473939667`*^9}},ExpressionUUID->"71c8bcc5-a571-de40-9358-\
643afde52c40"],

Cell[BoxData[
 RowBox[{
  RowBox[{"x", "=", 
   FractionBox["xyz", "yz"]}], ",", " ", 
  RowBox[{"y", "=", 
   FractionBox["xyz", "xz"]}], ",", " ", 
  RowBox[{"z", "=", 
   FractionBox["xyz", "xy"]}]}]], "Input",
 CellChangeTimes->{{3.9904534630067196`*^9, 3.9904534913117657`*^9}, {
  3.9904535552867146`*^9, 
  3.990453572960682*^9}},ExpressionUUID->"b58ada4c-d645-3043-8399-\
bcc407bd4f64"],

Cell["\<\
This approach avoids solving a full system of equations and reduces the \
problem to a simple division once the areas are known.\
\>", "Text",
 CellChangeTimes->{{3.99045358157992*^9, 3.9904535865098457`*^9}, 
   3.990461608024132*^9},ExpressionUUID->"398fab66-02fc-f545-987f-\
35b93ce3b113"]
}, Open  ]],

Cell[CellGroupData[{

Cell["4.4 Systematic Search", "Subsection",
 CellChangeTimes->{{3.6943454921732183`*^9, 3.6943455089276485`*^9}, 
   3.9904535966306705`*^9, 3.991286405940834*^9, 
   3.991300002605234*^9},ExpressionUUID->"64d905b6-1c05-4671-a397-\
d9051e682947"],

Cell[TextData[{
 "Since A4 is fully determined by A1, A2, and A3 via De ",
 StyleBox["Gua\[CloseCurlyQuote]s",
  IgnoreSpellCheck->True],
 " Theorem, the problem reduces to searching all integer triplets (A1, A2, \
A3) and checking whether the resulting A4 is also a natural number and the \
total sum equals 18. To account for all valid arrangements, permutations of \
the leg areas are considered as distinct solutions. This search is \
implemented in Mathematica as follows:"
}], "Text",
 CellChangeTimes->{{3.6551323318137064`*^9, 3.655132346618133*^9}, {
  3.6558834788297663`*^9, 3.655883482105772*^9}, {3.655883581805547*^9, 
  3.655883589683561*^9}, {3.6558837346868153`*^9, 3.655883735919217*^9}, {
  3.694341574232729*^9, 3.694341596852769*^9}, {3.694342244717239*^9, 
  3.694342247462844*^9}, {3.694342333660995*^9, 3.694342343083412*^9}, {
  3.6943424202555304`*^9, 3.694342429299047*^9}, {3.6943424762647333`*^9, 
  3.694342484642213*^9}, {3.694342535512122*^9, 3.694342552269081*^9}, {
  3.6943425832578535`*^9, 3.694342597036641*^9}, {3.694342646046445*^9, 
  3.694342765915301*^9}, {3.694342880577859*^9, 3.694342892973568*^9}, {
  3.920005136849468*^9, 3.9200051373384686`*^9}, {3.9904536031079235`*^9, 
  3.9904536133700294`*^9}},ExpressionUUID->"720fd0cf-3b1a-5641-91db-\
187a96969d99"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{" ", 
  RowBox[{
   RowBox[{
    RowBox[{"solutions", "=", 
     RowBox[{"{", "}"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"A4", "=", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{"A1", "^", "2"}], "+", 
          RowBox[{"A2", "^", "2"}], "+", 
          RowBox[{"A3", "^", "2"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"IntegerQ", "[", "A4", "]"}], "&&", 
          RowBox[{
           RowBox[{"A1", "+", "A2", "+", "A3", "+", "A4"}], "==", "18"}]}], ",", 
         RowBox[{"AppendTo", "[", 
          RowBox[{"solutions", ",", 
           RowBox[{"{", 
            RowBox[{"A1", ",", "A2", ",", "A3", ",", "A4"}], "}"}]}], "]"}]}],
         "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"A1", ",", "1", ",", "15"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"A2", ",", "1", ",", "15"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"A3", ",", "1", ",", "15"}], "}"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"Grid", "[", 
    RowBox[{
     RowBox[{"Prepend", "[", 
      RowBox[{"solutions", ",", 
       RowBox[{"{", 
        RowBox[{"\"\<A1\>\"", ",", "\"\<A2\>\"", ",", "\"\<A3\>\"", 
         ",", "\"\<A4\>\""}], "}"}]}], "]"}], ",", 
     RowBox[{"Frame", "->", "All"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{
  3.6943456316374636`*^9, 3.990453619827881*^9, {3.9906829215736275`*^9, 
   3.9906829351026287`*^9}, {3.9912867033839455`*^9, 3.9912867062242737`*^9}, 
   3.9912877869866543`*^9},ExpressionUUID->"63973c09-62b7-45ce-8eee-\
a870279ee06a"],

Cell[BoxData[
 TagBox[GridBox[{
    {"\<\"A1\"\>", "\<\"A2\"\>", "\<\"A3\"\>", "\<\"A4\"\>"},
    {"2", "3", "6", "7"},
    {"2", "6", "3", "7"},
    {"3", "2", "6", "7"},
    {"3", "6", "2", "7"},
    {"6", "2", "3", "7"},
    {"6", "3", "2", "7"}
   },
   AutoDelete->False,
   GridBoxFrame->{"Columns" -> {{True}}, "Rows" -> {{True}}},
   GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
  "Grid"]], "Output",
 CellChangeTimes->{3.990453628937849*^9},
 CellLabel->"Out[3]=",ExpressionUUID->"c4d54ae6-24d7-5248-a6b1-7783ab899168"]
}, Open  ]],

Cell[TextData[{
 "Each permutation corresponds to a different assignment of the edge lengths \
x, y, z and therefore a geometrically distinct tetrahedron, even though the \
set of surface areas remains identical . A4 remains 7 in all cases since De ",
 StyleBox["Gua",
  IgnoreSpellCheck->True],
 "' s Theorem is symmetric in A1, A2, A3 ."
}], "Text",
 CellChangeTimes->{{3.9904536391327705`*^9, 3.9904536452437515`*^9}, {
  3.990682566759636*^9, 
  3.99068256781744*^9}},ExpressionUUID->"e5c14535-7fa6-b243-a682-\
e2864d6e6ac2"]
}, Open  ]],

Cell[CellGroupData[{

Cell["4.5 Continuous Optimization Check (NMinimize)", "Subsection",
 CellChangeTimes->{{3.991221813619274*^9, 3.991221814605257*^9}, 
   3.9912218792876987`*^9, {3.991230127363014*^9, 3.9912301386490726`*^9}, {
   3.9912303789258137`*^9, 3.991230379046133*^9}, {3.9912370527679157`*^9, 
   3.991237053047228*^9}, {3.991286151189535*^9, 3.991286151319729*^9}, 
   3.991286411325926*^9, {3.9912867597496223`*^9, 3.9912867616588573`*^9}, {
   3.9912999588233547`*^9, 3.991299959352764*^9}, 3.9913000052049274`*^9, {
   3.991314962784464*^9, 
   3.9913149661909046`*^9}},ExpressionUUID->"f84e6924-7c43-cc4a-9ac6-\
85a801a8f517"],

Cell[TextData[{
 "As a cross-check, we also treat the problem continuously. The four face \
areas are written as functions of the edge lengths x, y, z, and the same \
quality function is minimized over all positive real x, y, z using ",
 StyleBox["NMinimize",
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{{3.991316068393078*^9, 
  3.991316090367941*^9}},ExpressionUUID->"7d8b744c-ebbd-1b4a-a398-\
8f6a277045a5"],

Cell["\<\
The cell below defines the four areas, minimizes the quality function, and \
then verifies the result by recomputing the areas and their total at the \
optimum.\
\>", "Text",
 CellChangeTimes->{{3.991439333405121*^9, 
  3.9914393400743923`*^9}},ExpressionUUID->"31217cdd-7a9a-e849-8820-\
b55e5107f380"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Define", ",", 
    RowBox[{
     RowBox[{
     "minimize", " ", "and", " ", "verify", " ", "in", " ", "one", " ", 
      "cell"}], "==="}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Clear", "[", 
     RowBox[{
     "A1", ",", "A2", ",", "A3", ",", "A4", ",", "QF", ",", "x", ",", "y", ",",
       "z"}], "]"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"A1", "[", 
      RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"x", "*", "y"}], ")"}], "/", "2"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"A2", "[", 
      RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"x", "*", "z"}], ")"}], "/", "2"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"A3", "[", 
      RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"y", "*", "z"}], ")"}], "/", "2"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"A4", "[", 
      RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", "2"}], ")"}], "*", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"x", "^", "2"}], "*", 
         RowBox[{"y", "^", "2"}]}], "+", 
        RowBox[{
         RowBox[{"x", "^", "2"}], "*", 
         RowBox[{"z", "^", "2"}]}], "+", 
        RowBox[{
         RowBox[{"y", "^", "2"}], "*", 
         RowBox[{"z", "^", "2"}]}]}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"QF", "[", 
      RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"A1", "[", 
         RowBox[{"x", ",", "y", ",", "z"}], "]"}], "+", 
        RowBox[{"A2", "[", 
         RowBox[{"x", ",", "y", ",", "z"}], "]"}], "+", 
        RowBox[{"A3", "[", 
         RowBox[{"x", ",", "y", ",", "z"}], "]"}], "+", 
        RowBox[{"A4", "[", 
         RowBox[{"x", ",", "y", ",", "z"}], "]"}], "-", "18"}], ")"}], "^", 
      "2"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"sol", "=", 
     RowBox[{"NMinimize", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"QF", "[", 
          RowBox[{"x", ",", "y", ",", "z"}], "]"}], ",", 
         RowBox[{"x", ">", "0"}], ",", 
         RowBox[{"y", ">", "0"}], ",", 
         RowBox[{"z", ">", "0"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "y", ",", "z"}], "}"}], ",", 
       RowBox[{"AccuracyGoal", "->", "10"}], ",", 
       RowBox[{"PrecisionGoal", "->", "10"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"x0", ",", "y0", ",", "z0"}], "}"}], "=", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"x", ",", "y", ",", "z"}], "}"}], "/.", " ", 
      RowBox[{"sol", "[", 
       RowBox[{"[", "2", "]"}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"areas", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"A1", "[", 
        RowBox[{"x0", ",", "y0", ",", "z0"}], "]"}], ",", 
       RowBox[{"A2", "[", 
        RowBox[{"x0", ",", "y0", ",", "z0"}], "]"}], ",", 
       RowBox[{"A3", "[", 
        RowBox[{"x0", ",", "y0", ",", "z0"}], "]"}], ",", 
       RowBox[{"A4", "[", 
        RowBox[{"x0", ",", "y0", ",", "z0"}], "]"}]}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<sol   = \>\"", ",", "sol"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<areas = \>\"", ",", "areas"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<total = \>\"", ",", 
      RowBox[{"Total", "[", "areas", "]"}]}], "]"}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.991221874136017*^9, 3.991221874136017*^9}, 
   3.9912219307479763`*^9, {3.991222007567152*^9, 3.9912220309374657`*^9}, {
   3.991230081948139*^9, 3.9912300976937656`*^9}, {3.991230141409546*^9, 
   3.991230152640049*^9}, 3.9912304605295124`*^9, {3.991232103307373*^9, 
   3.991232148585413*^9}, {3.9912365817191334`*^9, 3.9912365894101295`*^9}, {
   3.9912872232579193`*^9, 3.991287227119295*^9}, {3.9912876836173306`*^9, 
   3.991287684551731*^9}, {3.9912882057510223`*^9, 3.991288235861704*^9}, {
   3.9912883402734203`*^9, 3.991288343865116*^9}, 3.991288426504118*^9, {
   3.9912886590665703`*^9, 3.991288690549307*^9}, {3.991288720879923*^9, 
   3.991288724451214*^9}, {3.991288805519514*^9, 3.99128882915707*^9}, {
   3.991288944417383*^9, 3.991288984795681*^9}, {3.9912891323081245`*^9, 
   3.991289140045479*^9}, {3.99128932523246*^9, 3.991289331136093*^9}, {
   3.991289375452099*^9, 3.9912893789873886`*^9}, {3.9914383487468204`*^9, 
   3.991438367782179*^9}, {3.991438489840828*^9, 
   3.9914384948214207`*^9}},ExpressionUUID->"084979a5-a285-2146-8a2a-\
63b3af9e08c4"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{"Results", ":"}]}]], "Input",
