Cell["From any solution the tetrahedron can be reconstructed via", "Text",
 CellChangeTimes->{{3.991477007367882*^9, 
  3.991477009868658*^9}},ExpressionUUID->"db7f23cd-b5f0-1040-a90f-\
5cd73b4a84c9"],

Cell[BoxData[
 RowBox[{"x", "=", 
  RowBox[{
   SqrtBox[
    FractionBox[
     RowBox[{"2", 
      SubscriptBox["A", "1"], 
      SubscriptBox["A", "2"]}], 
     SubscriptBox["A", "3"]]], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"and", " ", "similarly", " ", "for", " ", "y"}], ",", "z"}], 
    ")"}]}]}]], "Input",
 CellChangeTimes->{{3.9914770540194683`*^9, 3.9914770540194683`*^9}, {
