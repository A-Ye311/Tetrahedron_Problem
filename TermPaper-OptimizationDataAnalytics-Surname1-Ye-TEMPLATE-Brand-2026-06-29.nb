Cell[CellGroupData[{

Cell["5.1 ", "Subsection",
 CellChangeTimes->{{3.6943454921732183`*^9, 3.694345497976429*^9}, 
   3.6943455631221437`*^9, 
   3.9912807027466908`*^9},ExpressionUUID->"e266913f-bfaa-480f-bc1f-\
1495575a462c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"i", "=", "4"}], ",", 
   RowBox[{"i", "<=", "100"}], ",", 
   RowBox[{"i", "++"}], ",", 
   RowBox[{
    RowBox[{"solutions", "=", 
     RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"A1", "+", "A2", "+", "A3", "+", "A4"}], "==", "i"}], "&&", 
         RowBox[{
          RowBox[{"A4", "^", "2"}], "==", 
          RowBox[{
           RowBox[{"A1", "^", "2"}], "+", 
           RowBox[{"A2", "^", "2"}], "+", 
           RowBox[{"A3", "^", "2"}]}]}]}], ",", 
        RowBox[{"AppendTo", "[", 
         RowBox[{"solutions", ",", 
          RowBox[{"{", 
           RowBox[{"A1", ",", "A2", ",", "A3", ",", "A4"}], "}"}]}], "]"}]}], 
       "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"A1", ",", "1", ",", 
        RowBox[{"i", "-", "3"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"A2", ",", "A1", ",", 
        RowBox[{"i", "-", "3"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"A3", ",", "A2", ",", 
        RowBox[{"i", "-", "3"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"A4", ",", "A3", ",", 
        RowBox[{"i", "-", "3"}]}], "}"}]}], "   ", "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Length", "[", "solutions", "]"}], ">", "0"}], ",", 
      RowBox[{
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Summe = \>\"", ",", "i"}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"Grid", "[", 
         RowBox[{
          RowBox[{"Prepend", "[", 
           RowBox[{"solutions", ",", 
            RowBox[{"{", 
             
             RowBox[{"\"\<A1\>\"", ",", "\"\<A2\>\"", ",", "\"\<A3\>\"", 
              ",", "\"\<A4\>\""}], "}"}]}], "]"}], ",", 
          RowBox[{"Frame", "->", "All"}]}], "]"}], "]"}]}]}], "]"}]}]}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.9912807813906345`*^9, 3.991280784005108*^9}, {
   3.9912808560559483`*^9, 3.9912809022757587`*^9}, {3.9912809471875515`*^9, 
