Cell["\<\
Each permutation corresponds to a different assignment of the edge lengths x, \
y, z and therefore a geometrically distinct tetrahedron, even though the set \
of surface areas remains identical . A4 remains 7 in all cases since De Gua' \
s Theorem is symmetric in A1, A2, A3 .\
\>", "Text",
 CellChangeTimes->{{3.9904536391327705`*^9, 3.9904536452437515`*^9}, {
  3.990682566759636*^9, 
  3.99068256781744*^9}},ExpressionUUID->"e5c14535-7fa6-b243-a682-\
e2864d6e6ac2"]
}, Open  ]],

Cell[CellGroupData[{

Cell["4.5 Continuous Optimization Check (NMinimize)", "Subsection",
 CellChangeTimes->{{3.991221813619274*^9, 3.991221814605257*^9}, 
   3.9912218792876987`*^9, {3.991230127363014*^9, 3.9912301386490726`*^9}, {
   3.9912303789258137`*^9, 3.991230379046133*^9}, {3.9912370527679157`*^9, 
   3.991237053047228*^9}, {3.991286151189535*^9, 3.991286151319729*^9}, 
   3.991286411325926*^9, {3.9912867597496223`*^9, 3.9912867616588573`*^9}, {
   3.9912999588233547`*^9, 3.991299959352764*^9}, 3.9913000052049274`*^9, {
   3.991314962784464*^9, 
   3.9913149661909046`*^9}},ExpressionUUID->"f84e6924-7c43-cc4a-9ac6-\
85a801a8f517"],

Cell[TextData[{
 "As a cross-check, we also treat the problem continuously. The four face \
areas are written as functions of the edge lengths x, y, z, and the same \
quality function is minimized over all positive real x, y, z using ",
 StyleBox["NMinimize",
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{{3.991316068393078*^9, 
  3.991316090367941*^9}},ExpressionUUID->"7d8b744c-ebbd-1b4a-a398-\
8f6a277045a5"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"A1", "[", 
    RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"x", "*", "y"}], ")"}], "/", "2"}]}], " "}], "\n", 
 RowBox[{
  RowBox[{"A2", "[", 
   RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"x", "*", "z"}], ")"}], "/", "2"}]}], "\n", 
 RowBox[{
  RowBox[{"A3", "[", 
   RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"y", "*", "z"}], ")"}], "/", "2"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"A4", "[", 
    RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "/", "2"}], ")"}], "*", 
    RowBox[{"Sqrt", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"x", "^", "2"}], "*", 
       RowBox[{"y", "^", "2"}]}], "+", 
      RowBox[{
       RowBox[{"x", "^", "2"}], "*", 
       RowBox[{"z", "^", "2"}]}], "+", 
      RowBox[{
       RowBox[{"y", "^", "2"}], "*", 
       RowBox[{"z", "^", "2"}]}]}], "]"}]}]}], "\n", 
  RowBox[{"(*", 
   RowBox[{"Qualitiy", " ", "Function"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"QF", "[", 
    RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"A1", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}], "+", 
      RowBox[{"A2", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}], "+", 
      RowBox[{"A3", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}], "+", 
      RowBox[{"A4", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}], "-", "18"}], ")"}], "^", 
    "2"}]}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{"sol", "=", 
  RowBox[{"NMinimize", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"QF", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}], ",", 
      RowBox[{"x", ">", "0"}], ",", 
      RowBox[{"y", ">", "0"}], ",", 
      RowBox[{"z", ">", "0"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "y", ",", "z"}], "}"}], ",", " ", 
    RowBox[{"AccuracyGoal", "\[Rule]", "10"}], ",", 
    RowBox[{"PrecisionGoal", "\[Rule]", "10"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.991221874136017*^9, 3.991221874136017*^9}, 
   3.9912219307479763`*^9, {3.991222007567152*^9, 3.9912220309374657`*^9}, {
