Cell[BoxData[{
 RowBox[{
  RowBox[{
   SubscriptBox["A", "1"], "+", 
   SubscriptBox["A", "2"], "+", 
   SubscriptBox["A", "3"], "+", 
   SubscriptBox["A", "4"]}], " ", "=", " ", "18"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    SubscriptBox["A", "1"], "\[Epsilon]", " ", "\:2115", " ", "for", " ", 
    "i"}], "=", "1"}], ",", "2", ",", "3", ",", "4"}]}], "Input",
 CellChangeTimes->{{3.9904525072496223`*^9, 3.990452546243204*^9}, {
  3.990452929776308*^9, 
  3.990452962812275*^9}},ExpressionUUID->"b98937ea-69d2-fa45-b660-\
7534763fece7"],

Cell["\<\
The problem therefore reduces to finding all integer triplets (A1, A2, A3) \
such that the resulting A4 is also a natural number and the total sum equals \
18.\
\>", "Text",
 CellChangeTimes->{{3.990452977564764*^9, 
  3.990452983694853*^9}},ExpressionUUID->"729ceee0-54fc-f647-b396-\
eb7ac3166527"],

Cell["Based on our informations is this our Quality Function:", "Text",
 CellChangeTimes->{{3.9906843591271286`*^9, 3.990684378423479*^9}, {
  3.990684737170374*^9, 3.9906847544678955`*^9}, {3.9912861709361877`*^9, 
  3.9912861720278053`*^9}},ExpressionUUID->"881540b2-1e3a-da4c-b759-\
56a8c37e667b"],

Cell[BoxData[{
 RowBox[{"QF", "=", 
  RowBox[{
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["A", "1"], "+", 
      SubscriptBox["A", "2"], "+", 
      SubscriptBox["A", "3"], "+", 
      SubscriptBox["A", "4"], " ", "-", "18"}], ")"}], "2"], " ", "=", " ", 
   "0"}]}], "\[IndentingNewLine]", 
 RowBox[{"QF", " ", "=", " ", 
  RowBox[{
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["A", "1"], "+", 
      SubscriptBox["A", "2"], "+", 
      SubscriptBox["A", "3"], " ", "+", 
      SqrtBox[
       RowBox[{
        SubsuperscriptBox["A", "1", "2"], "+", 
        SubsuperscriptBox["A", "2", "2"], "+", 
        SubsuperscriptBox["A", "3", "2"]}]], "-", "18"}], ")"}], "2"], "=", 
   " ", "0"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"QF", 
   RowBox[{"(", 
    RowBox[{"x", ",", "y", ",", "z"}], ")"}]}], "=", " ", 
  RowBox[{
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      FractionBox["xy", "2"], "+", 
      FractionBox["xz", "2"], "+", 
      FractionBox["yz", "2"], " ", "+", " ", 
      FractionBox[
       SqrtBox[
        RowBox[{
         RowBox[{
          SuperscriptBox["x", "2"], 
          SuperscriptBox["y", "2"]}], "+", 
         RowBox[{
          SuperscriptBox["x", "2"], 
          SuperscriptBox["z", "2"]}], "+", 
         RowBox[{
          SuperscriptBox["y", "2"], 
          SuperscriptBox["z", "2"]}]}]], "2"], " ", "-", "18"}], ")"}], "2"], 
   " ", "=", " ", "0"}]}]}], "Input",
 CellChangeTimes->{{3.9912217155701447`*^9, 3.991221802499235*^9}, {
  3.99122191997538*^9, 
  3.99122192185968*^9}},ExpressionUUID->"1a05b1af-407d-304c-81a2-\
