Cell[CellGroupData[{

Cell["4.3", "Subsection",
 CellChangeTimes->{{3.9912367741371098`*^9, 3.9912368162119923`*^9}, {
  3.991237050030262*^9, 
  3.9912370502661705`*^9}},ExpressionUUID->"89abc913-11df-724b-a7fd-\
a47431a546bd"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"RecoverEdges", "[", 
     RowBox[{"A1_", ",", "A2_", ",", "A3_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "p", "}"}], ",", 
      RowBox[{
       RowBox[{"p", "=", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"8", "*", "A1", "*", "A2", "*", "A3"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"p", "/", 
          RowBox[{"(", 
           RowBox[{"2", "*", "A3"}], ")"}]}], ",", 
         RowBox[{"p", "/", 
          RowBox[{"(", 
           RowBox[{"2", "*", "A2"}], ")"}]}], ",", 
         RowBox[{"p", "/", 
          RowBox[{"(", 
           RowBox[{"2", "*", "A1"}], ")"}]}]}], "}"}]}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{"RecoverEdges", "[", 
  RowBox[{"2", ",", "3", ",", "6"}], "]"}]}], "Input",
 CellChangeTimes->{{3.9912370162655525`*^9, 3.9912370162655525`*^9}},
 CellLabel->"In[25]:=",ExpressionUUID->"bac8ba4c-1fd9-5145-916d-8138f7c3827e"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   SqrtBox["2"], ",", 
   RowBox[{"2", " ", 
    SqrtBox["2"]}], ",", 
   RowBox[{"3", " ", 
    SqrtBox["2"]}]}], "}"}]], "Output",
 CellChangeTimes->{3.9912370180637417`*^9},
 CellLabel->"Out[26]=",ExpressionUUID->"710da76c-eb73-0b46-958f-ad9da46b0c3a"]
}, Open  ]],

Cell["\<\
Each permutation of (A1, A2, A3) from the table in Section 4.2 yields a \
corresponding permutation of (x, y, z), confirming that the six solutions \
found represent six geometrically distinct tetrahedra .\
\>", "Text",
 CellChangeTimes->{{3.9912370808813095`*^9, 
  3.9912371358795643`*^9}},ExpressionUUID->"529de5b8-1730-164a-8cb8-\
4d4b4d4d370b"]
}, Open  ]]
}, Open  ]]
