   3.694341574232729*^9, 3.694341596852769*^9}, {3.694342244717239*^9, 
   3.694342247462844*^9}, {3.694342333660995*^9, 3.694342343083412*^9}, {
   3.6943424202555304`*^9, 3.694342429299047*^9}, {3.6943424762647333`*^9, 
   3.694342484642213*^9}, {3.694342535512122*^9, 3.694342552269081*^9}, {
   3.6943425832578535`*^9, 3.694342597036641*^9}, {3.694342646046445*^9, 
   3.694342765915301*^9}, {3.694342880577859*^9, 3.694342892973568*^9}, {
   3.920005136849468*^9, 3.9200051373384686`*^9}, {3.991454903470379*^9, 
   3.991454953857952*^9}, {3.9914758816196175`*^9, 3.991475919448164*^9}, 
   3.991475970619261*^9},ExpressionUUID->"90483382-5eb0-d448-a807-\
fd35b3697047"],

Cell["the total must be even (Section 6.3), ", "Subitem",
 CellChangeTimes->{{3.9914759492052917`*^9, 
  3.991475961287283*^9}},ExpressionUUID->"a0490d2a-badb-d843-8292-\
c142788627c9"],

Cell["\<\
and even then solutions exist only for some totals, growing in number as S \
increases. \
\>", "Subitem",
