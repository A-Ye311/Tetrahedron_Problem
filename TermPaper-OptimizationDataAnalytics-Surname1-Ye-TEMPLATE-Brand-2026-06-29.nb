Cell[TextData[{
 "Following the ContourPlot3D approach from the lecture, this surface \
visualizes De ",
 StyleBox["Gua\[CloseCurlyQuote]s",
  IgnoreSpellCheck->True],
 " theorem directly. Using A4 = 7 (its value in the solution), the relation "
}], "Text",
 CellChangeTimes->{{3.9914452231256733`*^9, 3.9914452257170105`*^9}, 
   3.9914454694594955`*^9, {3.9914456659062634`*^9, 3.9914456776728497`*^9}, {
   3.9914457236039734`*^9, 
   3.9914457725007687`*^9}},ExpressionUUID->"8e0cf645-1f07-ca45-9deb-\
183673a1ed26"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubsuperscriptBox["A", "1", "2"], "+", 
   SubsuperscriptBox["A", "2", "2"], "+", 
   SubsuperscriptBox["A", "3", "2"]}], "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     SubsuperscriptBox["A", "4", "2"], "  ", "becomes", " ", 
     SubsuperscriptBox["A", "1", "2"]}], "+", 
    SubsuperscriptBox["A", "2", "2"], "+", 
    SubsuperscriptBox["A", "3", "2"]}], "=", "49"}]}]], "Input",
 CellChangeTimes->{{3.991445577986658*^9, 3.991445581725048*^9}, {
  3.9914456215676136`*^9, 
  3.9914456280007935`*^9}},ExpressionUUID->"93908d0d-3a07-e246-9d45-\
7447365637bd"],

Cell["\<\
- a sphere of radius 7 in the space of the three leg areas A1, A2, A3. \
\>", "Text",
 CellChangeTimes->{{3.991445778515312*^9, 
  3.991445804142254*^9}},ExpressionUUID->"de0bdf19-a5a2-f040-8655-\
3d786663c511"],

Cell["\<\
The integer solution (2, 3, 6) is the lattice point lying exactly on this \
sphere; together with A4 = 7 it produces the required total of 18.\
\>", "Text",
 CellChangeTimes->{
  3.9914458101857357`*^9},ExpressionUUID->"f63356b6-c8e7-444d-b6a4-\
e90318cc35fe"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["6 - Sensitivity Analysis", "Section",
 PageBreakAbove->True,
 CellChangeTimes->{{3.694341537930465*^9, 3.694341550254487*^9}, {
   3.694342355079833*^9, 3.694342363410248*^9}, 3.6943428651189747`*^9, {
   3.6943430193857985`*^9, 3.694343019923829*^9}, {3.6943431695433865`*^9, 
   3.694343174763685*^9}, 3.6943455517965236`*^9, 3.9200052201975765`*^9, {
   3.991300217647873*^9, 3.991300218454153*^9}, {3.991300360904604*^9, 
   3.991300361835661*^9}},ExpressionUUID->"b7395a63-f00d-488c-8531-\
cc9901abc9ed"],

Cell["\<\
The required total of 18 area units is only one possible value of the \
constraint. \
\>", "Text",
 CellChangeTimes->{{3.991447142695219*^9, 
  3.9914472030473022`*^9}},ExpressionUUID->"0ee1ee2b-3959-8648-a76b-\
b7fd35bc0fe0"],

Cell[TextData[{
 "To see how special it is, we vary the total-area target S over the whole \
range S = 4 to 100 and count, for each S, how many integer tetrahedra satisfy \
both the total-area constraint and De ",
 StyleBox["Gua\[CloseCurlyQuote]s",
  IgnoreSpellCheck->True],
 " theorem."
}], "Text",
 CellChangeTimes->{
  3.991447193759819*^9},ExpressionUUID->"98099108-d96f-e047-a45b-\
d9c0d0d352ea"],

Cell["\<\
This sweep is the sensitivity analysis, and it reveals a clear structural \
pattern.\
\>", "Text",
 CellChangeTimes->{
  3.991447208919731*^9},ExpressionUUID->"18047494-a7b0-a34d-a1b2-\
99cfc3c87415"],

Cell[CellGroupData[{

Cell["6.1 Solution Search", "Subsection",
 CellChangeTimes->{{3.6943454921732183`*^9, 3.694345497976429*^9}, 
   3.6943455631221437`*^9, 3.9912807027466908`*^9, {3.9913002218370094`*^9, 
   3.9913002223372765`*^9}, {3.991300269065201*^9, 3.9913002695212345`*^9}, 
   3.9914468568549404`*^9},ExpressionUUID->"e266913f-bfaa-480f-bc1f-\
1495575a462c"],

Cell["For each target S we test all sorted integer quadruples", "Text",
 CellChangeTimes->{{3.9914472448681564`*^9, 3.99144725942626*^9}, {
  3.991447328229801*^9, 3.9914473404831543`*^9}, {3.991447406921385*^9, 
  3.991447410920475*^9}},ExpressionUUID->"41cfa88d-d99d-f440-a21f-\
bc2e036f0f20"],

Cell[BoxData[
 RowBox[{"A1", "\[LessEqual]", " ", "A2", " ", "\[LessEqual]", " ", "A3", " ",
   "\[LessEqual]", " ", "A4"}]], "Input",
 CellChangeTimes->{{3.9914473709511433`*^9, 
  3.9914474020986137`*^9}},ExpressionUUID->"f421a6dd-3406-ef44-9516-\
06d093c1f538"],

Cell["whose sum is S and which satisfy", "Text",
 CellChangeTimes->{
  3.991447415499647*^9},ExpressionUUID->"92169287-c214-7341-ab89-\
98c3fff0c0c1"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubsuperscriptBox["A", "1", "2"], "+", 
   SubsuperscriptBox["A", "2", "2"], "+", 
   SubsuperscriptBox["A", "3", "2"]}], "=", 
  SubsuperscriptBox["A", "4", "2"], " "}]], "Input",
 CellChangeTimes->{
  3.9914473221435127`*^9},ExpressionUUID->"53ca938f-d682-a541-98ac-\
1cf6dc6dd9a1"],

Cell["\<\
The loop prints every total that admits at least one solution. The same \
search is also wrapped in a small reusable function so it can feed the plots \
below.\
\>", "Text",
 CellChangeTimes->{
  3.9914473342119656`*^9, {3.991449696372753*^9, 
   3.991449703785095*^9}},ExpressionUUID->"44b1a0b5-16be-b743-82c1-\
2ddfeca6049a"],

Cell[BoxData["Calculations"], "Input",ExpressionUUID->"952535be-43f6-0947-9998-74136cf281a8"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Clear", "[", 
    RowBox[{"A1", ",", "A2", ",", "A3", ",", "A4"}], "]"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SolutionPerSum", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\n", 
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"i", "=", "4"}], ",", 
   RowBox[{"i", "<=", "100"}], ",", 
   RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"solutions", "=", 
     RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"Do", "\[IndentingNewLine]", "[", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"A1", "+", "A2", "+", "A3", "+", "A4"}], "==", "i"}], "&&", 
         RowBox[{
          RowBox[{"A4", "^", "2"}], "==", 
          RowBox[{
           RowBox[{"A1", "^", "2"}], "+", 
           RowBox[{"A2", "^", "2"}], "+", 
           RowBox[{"A3", "^", "2"}]}]}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"AppendTo", "[", 
         RowBox[{"solutions", ",", 
          RowBox[{"{", 
           RowBox[{"A1", ",", "A2", ",", "A3", ",", "A4"}], "}"}]}], "]"}]}], 
       "]"}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"A1", ",", "1", ",", 
        RowBox[{"i", "-", "3"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"A2", ",", "A1", ",", 
        RowBox[{"i", "-", "3"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"A3", ",", "A2", ",", 
        RowBox[{"i", "-", "3"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"A4", ",", "A3", ",", 
        RowBox[{"i", "-", "3"}]}], "}"}]}], "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"AppendTo", "[", 
     RowBox[{"SolutionPerSum", ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", 
        RowBox[{"Length", "[", "solutions", "]"}]}], "}"}]}], "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{"stores", " ", "data", " ", "for", " ", "the", " ", "plots"}], 
     "*)"}], "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Length", "[", "solutions", "]"}], ">", "0"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Summe = \>\"", ",", "i"}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"Grid", "[", 
         RowBox[{
          RowBox[{"Prepend", "[", 
           RowBox[{"solutions", ",", 
            RowBox[{"{", 
             
             RowBox[{"\"\<A1\>\"", ",", "\"\<A2\>\"", ",", "\"\<A3\>\"", 
              ",", "\"\<A4\>\""}], "}"}]}], "]"}], ",", 
          RowBox[{"Frame", "->", "All"}]}], "]"}], "]"}]}]}], "]"}]}]}], 
  "\[IndentingNewLine]", "]"}]}], "Input",
 CellChangeTimes->{{3.9914497622998333`*^9, 3.991449833436388*^9}},
 CellLabel->"In[6]:=",ExpressionUUID->"050cfc1a-b8d5-7b46-904b-eb862abc5f21"],

