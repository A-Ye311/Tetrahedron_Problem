Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"solutionsForTotal", "[", "S_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"solutions", "=", 
       RowBox[{"{", "}"}]}], "}"}], ",", 
     RowBox[{
      RowBox[{"Do", "[", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"A1", "+", "A2", "+", "A3", "+", "A4"}], "==", "S"}], "&&", 
           RowBox[{
            RowBox[{"A4", "^", "2"}], "==", 
            RowBox[{
             RowBox[{"A1", "^", "2"}], "+", 
             RowBox[{"A2", "^", "2"}], "+", 
             RowBox[{"A3", "^", "2"}]}]}]}], ",", 
          RowBox[{"AppendTo", "[", 
           RowBox[{"solutions", ",", 
            RowBox[{"{", 
             RowBox[{"A1", ",", "A2", ",", "A3", ",", "A4"}], "}"}]}], 
           "]"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"A1", ",", "1", ",", 
          RowBox[{"S", "-", "3"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"A2", ",", "A1", ",", 
          RowBox[{"S", "-", "3"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"A3", ",", "A2", ",", 
          RowBox[{"S", "-", "3"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"A4", ",", "A3", ",", 
          RowBox[{"S", "-", "3"}]}], "}"}]}], "]"}], ";", 
      "\[IndentingNewLine]", "solutions"}]}], "]"}]}], 
  "\[IndentingNewLine]"}]], "Input",
 CellChangeTimes->{3.9914521326842976`*^9, 3.99145233465407*^9},
 CellLabel->"In[9]:=",ExpressionUUID->"1a0e5d3c-bfd3-b342-be2a-b6aafd096887"],

Cell["\<\
Of the 97 totals between 4 and 100, only 41 admit any integer solution. The \
smallest admissible totals are S = 8, 16 and 18, each with exactly one \
solution, and S = 18 gives the required answer (2, 3, 6, 7). \
\>", "Text",
 CellChangeTimes->{{3.9914521569706154`*^9, 3.9914521824220085`*^9}, {
  3.9914522440103188`*^9, 3.991452252543539*^9}, {3.9914522853875465`*^9, 
  3.9914523103669853`*^9}, {3.9914774274069576`*^9, 
  3.9914774309851074`*^9}},ExpressionUUID->"269c3e98-47f3-1b40-81a3-\
bc7a81f52ad1"],

Cell["\<\
As S grows the number of solutions tends to increase, reaching eight at S = \
96. Here each solution is a sorted set\
\>", "Text",
 CellChangeTimes->{
  3.9914523157861843`*^9},ExpressionUUID->"5ecbef5c-3db7-4045-baff-\
9f1acacf79e3"],

Cell[BoxData[
 RowBox[{"A1", "\[LessEqual]", " ", "A2", " ", "\[LessEqual]", " ", "A3", " ",
   "\[LessEqual]", " ", "A4"}]], "Input",ExpressionUUID->"1e28096d-fa97-1343-\
9c63-3945f588a38a"],

Cell["\<\
, so the six permutations listed in Section 4.4 for S = 18 all collapse to \
this single entry.\
\>", "Text",
 CellChangeTimes->{
  3.991452290268776*^9},ExpressionUUID->"2e4f7672-1154-d34c-8353-\
3e6eae00cef4"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"sols", "=", 
       RowBox[{"solutionsForTotal", "[", "S", "]"}]}], "}"}], ",", 
     RowBox[{"Column", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Style", "[", 
         RowBox[{
          RowBox[{"Row", "[", 
           RowBox[{"{", 
            
            RowBox[{"\"\<Total area S = \>\"", ",", "S", 
             ",", "\"\<   ->   \>\"", ",", 
             RowBox[{"Length", "[", "sols", "]"}], 
             ",", "\"\< solution(s)\>\""}], "}"}], "]"}], ",", "15"}], "]"}], 
        ",", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"sols", "===", 
           RowBox[{"{", "}"}]}], ",", 
          RowBox[{"Style", "[", 
           
           RowBox[{"\"\<No integer tetrahedron for this total (S odd, or no \
Pythagorean quadruple).\>\"", ",", "Red"}], "]"}], ",", 
          RowBox[{"Grid", "[", 
           RowBox[{
            RowBox[{"Prepend", "[", 
             RowBox[{"sols", ",", 
              RowBox[{"{", 
               
               RowBox[{"\"\<A1\>\"", ",", "\"\<A2\>\"", ",", "\"\<A3\>\"", 
                ",", "\"\<A4\>\""}], "}"}]}], "]"}], ",", 
            RowBox[{"Frame", "->", "All"}]}], "]"}]}], "]"}]}], "}"}], 
      "]"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"S", ",", "18", ",", "\"\<total area S\>\""}], "}"}], ",", "4", 
     ",", "100", ",", "1", ",", 
     RowBox[{"Appearance", "->", "\"\<Labeled\>\""}]}], "}"}]}], 
  "]"}]], "Input",
 CellChangeTimes->{3.9914523669328613`*^9},
 CellLabel->"In[10]:=",ExpressionUUID->"d674f952-b737-5541-9c3e-6e63232e2e27"],

