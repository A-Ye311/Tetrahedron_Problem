  3.694345762940171*^9, {3.9904519657512856`*^9, 3.9904520380841675`*^9}, {
   3.9913028276804276`*^9, 
   3.991302828325672*^9}},ExpressionUUID->"25190add-2924-467f-8bf7-\
975d689e5f07"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{
   SubscriptBox["A", "4"], "=", 
   FractionBox[
    SqrtBox[
     RowBox[{
      RowBox[{
       SuperscriptBox["x", "2"], 
       SuperscriptBox["y", "2"]}], "+", 
      RowBox[{
       SuperscriptBox["x", "2"], 
       SuperscriptBox["z", "2"]}], "+", 
      RowBox[{
       SuperscriptBox["y", "2"], 
       SuperscriptBox["z", "2"]}]}]], "2"]}]}]], "Input",
 CellChangeTimes->{{3.990452049130247*^9, 3.9904520520463448`*^9}, 
   3.990461602439844*^9, {3.9906832812104435`*^9, 3.9906833016273193`*^9}, 
   3.990684154159897*^9, 
   3.99130282475062*^9},ExpressionUUID->"d0827fd6-3b96-4547-9abf-\
3467114ac4c1"],

Cell["\<\
It can be shown that these four areas satisfy the following relationship:\
\>", "Text",
 CellChangeTimes->{{3.990452360340946*^9, 3.9904523648229504`*^9}, 
   3.99046159953784*^9},ExpressionUUID->"1f11e8a4-1f6a-eb4a-b68e-\
d0d88be7c629"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{
   RowBox[{
    SubsuperscriptBox["A", "1", "2"], "+", 
    SubsuperscriptBox["A", "2", "2"], "+", 
    SubsuperscriptBox["A", "3", "2"]}], "=", 
   SubsuperscriptBox["A", "4", "2"]}]}]], "Input",
 CellChangeTimes->{{3.9904523726403866`*^9, 3.990452383166353*^9}, {
   3.9904524299174633`*^9, 3.9904524798602295`*^9}, 
   3.991302820730669*^9},ExpressionUUID->"3a67858a-a745-cd4e-bf07-\
1051fb315b2c"],

Cell["\<\
This relationship is known as De Gua\[CloseCurlyQuote]s theorem, the \
three-dimensional analogue of the Pythagorean theorem. It shows that A4 is \
fully determined once A1, A2 and A3 are fixed, so the four face areas form a \
single dependent system rather than four free variables.

Our constraints: \
\>", "Text",
 CellChangeTimes->{{3.990452487888756*^9, 3.9904524971572075`*^9}, 
   3.990461595403324*^9, {3.9906830173495274`*^9, 3.9906830298910847`*^9}, {
   3.9906832285108643`*^9, 3.99068322894475*^9}, {3.990683265632801*^9, 
   3.9906832719112263`*^9}, {3.9906839107205906`*^9, 3.990683917779646*^9}, {
   3.991302761332239*^9, 3.9913027782983456`*^9}, {3.9913029778571568`*^9, 
   3.9913030084518814`*^9}},ExpressionUUID->"35b45854-3018-9941-af73-\
259516ab44b7"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{
   RowBox[{
    RowBox[{
     SubscriptBox["A", "1"], "+", 
     SubscriptBox["A", "2"], "+", 
     SubscriptBox["A", "3"], "+", 
     SubscriptBox["A", "4"]}], " ", "=", " ", "18"}], "\[IndentingNewLine]", 
   "\t", 
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["A", "1"], "\[Epsilon]", " ", "\:2115", " ", "for", " ", 
      "i"}], "=", "1"}], ",", "2", ",", "3", ",", "4"}]}]}]], "Input",
 CellChangeTimes->{{3.9904525072496223`*^9, 3.990452546243204*^9}, {
  3.990452929776308*^9, 3.990452962812275*^9}, {3.991302815730465*^9, 
  3.991302817480419*^9}},ExpressionUUID->"b98937ea-69d2-fa45-b660-\
7534763fece7"],

Cell["\<\
The problem therefore reduces to finding all integer triplets (A1, A2, A3) \
such that the resulting A4 is also a natural number and the total sum equals \
18.\
\>", "Text",
 CellChangeTimes->{{3.990452977564764*^9, 3.990452983694853*^9}, 
   3.9913028475147533`*^9, 
   3.991303020649431*^9},ExpressionUUID->"729ceee0-54fc-f647-b396-\
eb7ac3166527"],

Cell["\<\
Based on these conditions, we define the following quality function, which \
must be minimized to zero:\
\>", "Text",
 CellChangeTimes->{{3.9906843591271286`*^9, 3.990684378423479*^9}, {
  3.990684737170374*^9, 3.9906847544678955`*^9}, {3.9912861709361877`*^9, 
  3.9912861720278053`*^9}, {3.9913028677524757`*^9, 3.9913029181468678`*^9}, {
  3.9913030121171207`*^9, 
  3.991303015430853*^9}},ExpressionUUID->"881540b2-1e3a-da4c-b759-\
56a8c37e667b"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{
   RowBox[{"QF", "=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["A", "1"], "+", 
        SubscriptBox["A", "2"], "+", 
        SubscriptBox["A", "3"], "+", 
        SubscriptBox["A", "4"], " ", "-", "18"}], ")"}], "2"], " ", "=", " ", 
     "0"}]}], "\[IndentingNewLine]", "\t", 
   RowBox[{"QF", " ", "=", " ", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["A", "1"], "+", 
        SubscriptBox["A", "2"], "+", 
        SubscriptBox["A", "3"], " ", "+", 
        SqrtBox[
         RowBox[{
          SubsuperscriptBox["A", "1", "2"], "+", 
          SubsuperscriptBox["A", "2", "2"], "+", 
          SubsuperscriptBox["A", "3", "2"]}]], "-", "18"}], ")"}], "2"], "=", 
     " ", "0"}]}], "\[IndentingNewLine]", "\t", 
   RowBox[{
    RowBox[{"QF", 
     RowBox[{"(", 
      RowBox[{"x", ",", "y", ",", "z"}], ")"}]}], "=", " ", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        FractionBox["xy", "2"], "+", 
        FractionBox["xz", "2"], "+", 
        FractionBox["yz", "2"], " ", "+", " ", 
        FractionBox[
         SqrtBox[
          RowBox[{
           RowBox[{
            SuperscriptBox["x", "2"], 
            SuperscriptBox["y", "2"]}], "+", 
           RowBox[{
            SuperscriptBox["x", "2"], 
            SuperscriptBox["z", "2"]}], "+", 
           RowBox[{
            SuperscriptBox["y", "2"], 
            SuperscriptBox["z", "2"]}]}]], "2"], " ", "-", "18"}], ")"}], 
      "2"], " ", "=", " ", "0"}]}]}]}]], "Input",
 CellChangeTimes->{{3.9912217155701447`*^9, 3.991221802499235*^9}, {
  3.99122191997538*^9, 3.99122192185968*^9}, {3.9913029111623726`*^9, 
  3.9913029131977577`*^9}},ExpressionUUID->"1a05b1af-407d-304c-81a2-\
b82788b74035"],

Cell["\<\
The required total is 18, but the same quality function is evaluated for \
general targets S in Section 6, in order to study how the set of integer \
solutions depends on the total-area budget.\
\>", "Text",
 CellChangeTimes->{{3.9913030599303207`*^9, 
  3.9913030701823425`*^9}},ExpressionUUID->"887afe31-ae24-6d45-b262-\
ffe52d925c9c"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "4 - Solution",
 Cell[BoxData[""], "Input",
  CellChangeTimes->{{3.9906839291701984`*^9, 3.9906839335792427`*^9}, {
   3.9906840387992573`*^9, 3.990684115246788*^9}, {3.990684223587511*^9, 
   3.9906843393951073`*^9}},ExpressionUUID->
  "f47640dd-ba74-8849-8e2f-fb4b9945262a"]
}], "Section",
 PageBreakAbove->True,
 CellChangeTimes->{{3.694341537930465*^9, 3.694341550254487*^9}, {
   3.694342355079833*^9, 3.694342363410248*^9}, 3.6943428651189747`*^9, {
   3.6943430193857985`*^9, 3.694343019923829*^9}, {3.6943431695433865`*^9, 
   3.694343174763685*^9}, 3.694345457572358*^9, 3.9200052107218494`*^9, 
   3.9906839211539326`*^9, 3.9906840327960777`*^9, {3.990684425691986*^9, 
   3.9906844292832603`*^9}, {3.9912218087302246`*^9, 
   3.9912218097970066`*^9}, {3.991299977552162*^9, 
   3.991299977776375*^9}},ExpressionUUID->"e0ce679d-baae-4e3f-955a-\
2426a5ad958a"],

Cell[CellGroupData[{

Cell["4.1 Constraints", "Subsection",
 CellChangeTimes->{{3.9912863084491596`*^9, 3.9912863317361946`*^9}, 
   3.991286393110281*^9, {3.9912864313417435`*^9, 3.9912864318339024`*^9}, 
   3.991299993040222*^9},ExpressionUUID->"a4ec537c-5aeb-8e4d-a215-\
fc23444eefbe"],

Cell["The problem is subject to two constraints:", "Text",
 CellChangeTimes->{{3.991304057503212*^9, 3.9913040601725845`*^9}, {
  3.991304234757761*^9, 3.9913042590433655`*^9}, {3.991304939495865*^9, 
  3.99130494122287*^9}, {3.99131258234671*^9, 3.9913126185656624`*^9}, {
  3.9913126945223656`*^9, 
  3.9913127440168667`*^9}},ExpressionUUID->"d887f889-d87e-134f-8ec5-\
5d5e985f7f72"],

Cell["\<\
First, the four face areas must sum to the prescribed total of 18 area units. \
\>", "Text",
 CellChangeTimes->{
  3.991312622724415*^9, {3.9913127267275906`*^9, 
   3.991312728688284*^9}},ExpressionUUID->"ee718b03-75cb-9a49-bfd7-\
654bfe0a874e"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{
   RowBox[{
    SubscriptBox["A", "1"], "+", 
    SubscriptBox["A", "2"], "+", 
    SubscriptBox["A", "3"], "+", 
    SubscriptBox["A", "4"]}], " ", "=", " ", "18"}]}]], "Input",
 CellChangeTimes->{{3.9913126801910458`*^9, 3.9913126835109673`*^9}, 
   3.9913127307990093`*^9},ExpressionUUID->"9c81acdb-3a3d-7845-a248-\
078371dd7b5f"],

Cell["Second, each face area must be a natural number. ", "Text",
 CellChangeTimes->{
  3.9913126991551495`*^9},ExpressionUUID->"f4367371-2a08-b341-af2b-\
9e49dcfd7ed5"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{
   RowBox[{
    RowBox[{
     SubscriptBox["A", "1"], "\[Epsilon]", " ", "\:2115", " ", "for", " ", 
     "i"}], "=", "1"}], ",", "2", ",", "3", ",", "4"}]}]], "Input",
 CellChangeTimes->{
  3.9913127326360683`*^9},ExpressionUUID->"8f6a2b35-ad5f-6e4d-80ed-\
cc6f742f17e2"],

Cell[TextData[{
 "Combined with De ",
 StyleBox["Gua\[CloseCurlyQuote]s",
  IgnoreSpellCheck->True],
 " relation ",
 StyleBox["\[OpenCurlyDoubleQuote]A4^2 = A1^2 + A2^2 + A3^2\
\[CloseCurlyDoubleQuote]",
  FontWeight->"Bold"],
 " from Section 3, these conditions define the set of admissible solutions."
}], "Text",
 CellChangeTimes->{
  3.991312722856058*^9},ExpressionUUID->"f630584c-f1ca-b44c-8854-\
954119175195"]
}, Open  ]],

Cell[CellGroupData[{

Cell["4.2 Quality Function", "Subsection",
 CellChangeTimes->{{3.9912863404590282`*^9, 3.99128635267029*^9}, {
   3.991286433972349*^9, 3.991286434376028*^9}, 3.991299919251314*^9, 
   3.9912999951252117`*^9},ExpressionUUID->"9c4e0287-e2bc-c34d-9462-\
b196788f33d6"],

Cell[TextData[{
 "To express the total-area condition as an optimization objective, we define \
a quality function QF that ",
 StyleBox["squares the deviation of the total area from 18",
  FontWeight->"Bold"],
 ". This function is always non-negative and equals zero exactly when the \
constraint A1 + A2 + A3 + A4 = 18 holds. Minimizing QF to zero is therefore \
equivalent to satisfying the constraint."
}], "Text",
 CellChangeTimes->{{3.9913052806094055`*^9, 3.991305306862726*^9}, {
  3.991305363670595*^9, 
  3.9913053647457867`*^9}},ExpressionUUID->"4c268f6a-40f2-1e49-8a9d-\
7331651978e5"],

Cell[BoxData[{
 RowBox[{"QF", "=", 
  RowBox[{
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["A", "1"], "+", 
      SubscriptBox["A", "2"], "+", 
      SubscriptBox["A", "3"], "+", 
      SubscriptBox["A", "4"], " ", "-", "18"}], ")"}], "2"], " ", "=", " ", 
   "0"}]}], "\[IndentingNewLine]", 
 RowBox[{"QF", " ", "=", " ", 
  RowBox[{
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["A", "1"], "+", 
      SubscriptBox["A", "2"], "+", 
      SubscriptBox["A", "3"], " ", "+", 
      SqrtBox[
       RowBox[{
        SubsuperscriptBox["A", "1", "2"], "+", 
        SubsuperscriptBox["A", "2", "2"], "+", 
        SubsuperscriptBox["A", "3", "2"]}]], "-", "18"}], ")"}], "2"], "=", 
   " ", "0"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"QF", 
   RowBox[{"(", 
    RowBox[{"x", ",", "y", ",", "z"}], ")"}]}], "=", " ", 
  RowBox[{
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      FractionBox["xy", "2"], "+", 
      FractionBox["xz", "2"], "+", 
      FractionBox["yz", "2"], " ", "+", " ", 
      FractionBox[
       SqrtBox[
        RowBox[{
         RowBox[{
          SuperscriptBox["x", "2"], 
          SuperscriptBox["y", "2"]}], "+", 
         RowBox[{
          SuperscriptBox["x", "2"], 
          SuperscriptBox["z", "2"]}], "+", 
         RowBox[{
          SuperscriptBox["y", "2"], 
          SuperscriptBox["z", "2"]}]}]], "2"], " ", "-", "18"}], ")"}], "2"], 
   " ", "=", " ", "0"}]}]}], "Input",ExpressionUUID->"ed5bafb5-74d4-954c-b4f9-\
2de2abb1b1d7"]
}, Open  ]],

Cell[CellGroupData[{

Cell["4.3 Rearrange mathematical formula", "Subsection",
 CellChangeTimes->{{3.9906829694227276`*^9, 3.9906829885139256`*^9}, {
   3.990683240045719*^9, 3.990683253407587*^9}, 3.9906844331032734`*^9, 
   3.9912864035271473`*^9, 
   3.991299999711975*^9},ExpressionUUID->"fab2e7da-43b9-4640-a576-\
3039675e656a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    SubscriptBox["A", "1"], "\[Cross]", 
    SubscriptBox["A", "2"], "\[Cross]", 
    SubscriptBox["A", "3"]}], "=", 
   RowBox[{
    RowBox[{
     FractionBox["xy", "2"], "\[Cross]", 
     FractionBox["xz", "2"], "\[Cross]", 
     FractionBox["yz", "2"]}], "=", 
    FractionBox[
     RowBox[{
      SuperscriptBox["x", "2"], 
      SuperscriptBox["y", "2"], 
      SuperscriptBox["z", "2"]}], "8"]}]}], "\n"}]], "Input",
 CellChangeTimes->{{3.6551323318137064`*^9, 3.655132346618133*^9}, {
   3.6558834788297663`*^9, 3.655883482105772*^9}, {3.655883581805547*^9, 
   3.655883589683561*^9}, {3.6558837346868153`*^9, 3.655883735919217*^9}, {
   3.694341574232729*^9, 3.694341596852769*^9}, {3.694342244717239*^9, 
   3.694342247462844*^9}, {3.694342333660995*^9, 3.694342343083412*^9}, {
   3.6943424202555304`*^9, 3.694342429299047*^9}, {3.6943424762647333`*^9, 
   3.694342484642213*^9}, {3.694342535512122*^9, 3.694342552269081*^9}, {
   3.6943425832578535`*^9, 3.694342597036641*^9}, {3.694342646046445*^9, 
   3.694342765915301*^9}, {3.694342880577859*^9, 3.694342892973568*^9}, {
   3.920005136849468*^9, 3.9200051373384686`*^9}, 3.9904530490801907`*^9, {
   3.9906827032540646`*^9, 3.990682704525078*^9}, {3.9906827765189037`*^9, 
   3.9906827886063175`*^9}, 3.9906833458303394`*^9, 3.990683961678097*^9, 
   3.990684125702921*^9},ExpressionUUID->"dd5889fc-b7b8-1e4d-ac00-\
ef278f9515c5"],

Cell["This directly implies :", "Text",
 CellChangeTimes->{{3.9904533680979443`*^9, 
  3.990453374316719*^9}},ExpressionUUID->"331375c1-06b3-d64d-9699-\
03811dec39d2"],

Cell[BoxData[
 RowBox[{"xyz", "=", 
  SqrtBox[
   RowBox[{"8", "\[Cross]", 
    SubscriptBox["A", "1"], "\[Cross]", 
    SubscriptBox["A", "2"], "\[Cross]", 
    SubscriptBox["A", "3"]}]]}]], "Input",
 CellChangeTimes->{{3.9904533788595943`*^9, 
  3.990453433315296*^9}},ExpressionUUID->"70f4aa1f-3c70-9f4b-bd8c-\
b78306e40325"],

Cell[TextData[{
 "Once ",
 StyleBox["xyz",
  IgnoreSpellCheck->True],
 " is known, the individual edge lengths can be recovered by dividing through \
the respective face products :"
}], "Text",
 CellChangeTimes->{{3.990453439516323*^9, 
  3.9904534473939667`*^9}},ExpressionUUID->"71c8bcc5-a571-de40-9358-\
643afde52c40"],

Cell[BoxData[
 RowBox[{
  RowBox[{"x", "=", 
   FractionBox["xyz", "yz"]}], ",", " ", 
  RowBox[{"y", "=", 
   FractionBox["xyz", "xz"]}], ",", " ", 
  RowBox[{"z", "=", 
   FractionBox["xyz", "xy"]}]}]], "Input",
 CellChangeTimes->{{3.9904534630067196`*^9, 3.9904534913117657`*^9}, {
  3.9904535552867146`*^9, 
  3.990453572960682*^9}},ExpressionUUID->"b58ada4c-d645-3043-8399-\
bcc407bd4f64"],

Cell["\<\
This approach avoids solving a full system of equations and reduces the \
problem to a simple division once the areas are known.\
\>", "Text",
 CellChangeTimes->{{3.99045358157992*^9, 3.9904535865098457`*^9}, 
   3.990461608024132*^9},ExpressionUUID->"398fab66-02fc-f545-987f-\
35b93ce3b113"]
}, Open  ]],

Cell[CellGroupData[{

Cell["4.4 Systematic Search", "Subsection",
 CellChangeTimes->{{3.6943454921732183`*^9, 3.6943455089276485`*^9}, 
   3.9904535966306705`*^9, 3.991286405940834*^9, 
   3.991300002605234*^9},ExpressionUUID->"64d905b6-1c05-4671-a397-\
d9051e682947"],

Cell[TextData[{
 "Since A4 is fully determined by A1, A2, and A3 via De ",
 StyleBox["Gua\[CloseCurlyQuote]s",
  IgnoreSpellCheck->True],
 " Theorem, the problem reduces to searching all integer triplets (A1, A2, \
A3) and checking whether the resulting A4 is also a natural number and the \
total sum equals 18. To account for all valid arrangements, permutations of \
the leg areas are considered as distinct solutions. This search is \
implemented in Mathematica as follows:"
}], "Text",
 CellChangeTimes->{{3.6551323318137064`*^9, 3.655132346618133*^9}, {
  3.6558834788297663`*^9, 3.655883482105772*^9}, {3.655883581805547*^9, 
  3.655883589683561*^9}, {3.6558837346868153`*^9, 3.655883735919217*^9}, {
  3.694341574232729*^9, 3.694341596852769*^9}, {3.694342244717239*^9, 
  3.694342247462844*^9}, {3.694342333660995*^9, 3.694342343083412*^9}, {
  3.6943424202555304`*^9, 3.694342429299047*^9}, {3.6943424762647333`*^9, 
  3.694342484642213*^9}, {3.694342535512122*^9, 3.694342552269081*^9}, {
  3.6943425832578535`*^9, 3.694342597036641*^9}, {3.694342646046445*^9, 
  3.694342765915301*^9}, {3.694342880577859*^9, 3.694342892973568*^9}, {
  3.920005136849468*^9, 3.9200051373384686`*^9}, {3.9904536031079235`*^9, 
  3.9904536133700294`*^9}},ExpressionUUID->"720fd0cf-3b1a-5641-91db-\
187a96969d99"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{" ", 
  RowBox[{
   RowBox[{
    RowBox[{"solutions", "=", 
     RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"A4", "=", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{"A1", "^", "2"}], "+", 
          RowBox[{"A2", "^", "2"}], "+", 
          RowBox[{"A3", "^", "2"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"IntegerQ", "[", "A4", "]"}], "&&", 
          RowBox[{
           RowBox[{"A1", "+", "A2", "+", "A3", "+", "A4"}], "==", "18"}]}], ",", 
         RowBox[{"AppendTo", "[", 
          RowBox[{"solutions", ",", 
           RowBox[{"{", 
            RowBox[{"A1", ",", "A2", ",", "A3", ",", "A4"}], "}"}]}], "]"}]}],
         "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"A1", ",", "1", ",", "15"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"A2", ",", "1", ",", "15"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"A3", ",", "1", ",", "15"}], "}"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"Grid", "[", 
    RowBox[{
     RowBox[{"Prepend", "[", 
      RowBox[{"solutions", ",", 
       RowBox[{"{", 
        RowBox[{"\"\<A1\>\"", ",", "\"\<A2\>\"", ",", "\"\<A3\>\"", 
         ",", "\"\<A4\>\""}], "}"}]}], "]"}], ",", 
